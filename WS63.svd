    <!-- ============================================================ -->
    <!-- SFC_CFG: SPI Flash Controller (Base: 0x48000000)            -->
    <!-- ============================================================ -->
    <peripheral>
      <name>SFC_CFG</name>
      <description>SPI Flash Controller configuration</description>
      <baseAddress>0x48000000</baseAddress>
      <interrupt><name>SFC_INT</name><value>58</value></interrupt>
      <registers>
        <register><name>GLOBAL_CONFIG</name><description>Global configuration register</description><addressOffset>0x0100</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>mode</name><description>SPI mode: 0=Mode0; 1=Mode3</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>wp_en</name><description>Hardware write protect: 0=disabled; 1=enabled</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>flash_addr_mode</name><description>Address mode: 0=3byte; 1=4byte</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>rd_delay</name><description>SPI read data delay: 000=0.5~1clk; 001=1~1.5clk; etc.</description><bitRange>[5:3]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TIMING</name><description>Timing configuration register</description><addressOffset>0x0110</addressOffset><resetValue>0x0000660F</resetValue><fields><field><name>tshsl</name><description>Inter-operation delay: (n+2) clock cycles</description><bitRange>[3:0]</bitRange><access>read-write</access></field><field><name>tcss</name><description>CS setup time: (n+1) clock cycles</description><bitRange>[10:8]</bitRange><access>read-write</access></field><field><name>tcsh</name><description>CS hold time: (n+1) clock cycles</description><bitRange>[14:12]</bitRange><access>read-write</access></field></fields></register>
        <register><name>INT_RAW_STATUS</name><description>Interrupt raw status register</description><addressOffset>0x0120</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cmd_op_end_raw_status</name><description>Command operation end raw status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>dma_done_int_raw_status</name><description>DMA done raw status</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
        <register><name>INT_STATUS</name><description>Interrupt status register (masked)</description><addressOffset>0x0124</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cmd_op_end_status</name><description>Command operation end status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>dma_done_int_status</name><description>DMA done status</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
        <register><name>INT_MASK</name><description>Interrupt mask register</description><addressOffset>0x0128</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cmd_op_end_int_mask</name><description>Command end mask: 0=masked; 1=unmasked</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>dma_done_int_mask</name><description>DMA done mask</description><bitRange>[1:1]</bitRange><access>read-write</access></field></fields></register>
        <register><name>INT_CLEAR</name><description>Interrupt clear register</description><addressOffset>0x012C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cmd_op_end_int_clr</name><description>Command end interrupt clear (self-clearing)</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>dma_done_int_clr</name><description>DMA done interrupt clear (self-clearing)</description><bitRange>[1:1]</bitRange><access>write-only</access></field></fields></register>
        <register><name>SOFT_RST_MASK</name><description>Soft reset mask register</description><addressOffset>0x0130</addressOffset><resetValue>0x00000001</resetValue><fields><field><name>sfc_bus_soft_rst_mask</name><description>SFC bus soft reset mask: 0=reset active; 1=reset masked</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_CONFIG1</name><description>Bus operation config 1</description><addressOffset>0x0200</addressOffset><resetValue>0x80800300</resetValue><fields><field><name>rd_mem_if_type</name><description>Read SPI interface type: 000=Standard; 001=Dual I/O; 010=Dual-IO; 101=Quad-Input; 110=Quad-IO</description><bitRange>[2:0]</bitRange><access>read-write</access></field><field><name>rd_dummy_bytes</name><description>Read dummy bytes: 000=0; 001=1; etc.</description><bitRange>[5:3]</bitRange><access>read-write</access></field><field><name>rd_prefetch_cnt</name><description>Read prefetch count: 00=none; 01=1clk; 10=2clk; 11=3clk</description><bitRange>[7:6]</bitRange><access>read-write</access></field><field><name>rd_ins</name><description>Read instruction code</description><bitRange>[15:8]</bitRange><access>read-write</access></field><field><name>wr_mem_if_type</name><description>Write SPI interface type</description><bitRange>[18:16]</bitRange><access>read-write</access></field><field><name>wr_dummy_bytes</name><description>Write dummy bytes</description><bitRange>[21:19]</bitRange><access>read-write</access></field><field><name>wr_ins</name><description>Write instruction code</description><bitRange>[29:22]</bitRange><access>read-write</access></field><field><name>wr_enable</name><description>Bus write enable</description><bitRange>[30:30]</bitRange><access>read-write</access></field><field><name>rd_enable</name><description>Bus read enable</description><bitRange>[31:31]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_CONFIG2</name><description>Bus operation config 2</description><addressOffset>0x0204</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wip_locate</name><description>WIP bit position in Flash status register: 000=bit0; etc.</description><bitRange>[2:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_DMA_CTRL</name><description>DMA operation control register</description><addressOffset>0x0240</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dma_start</name><description>DMA transfer enable (auto-clears)</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>dma_rw</name><description>DMA direction: 0=write; 1=read</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>dma_sel_cs</name><description>DMA chip select: 0=CS0; 1=CS1</description><bitRange>[4:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_DMA_MEM_SADDR</name><description>DMA memory start address</description><addressOffset>0x0244</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dma_mem_saddr</name><description>DMA memory start address (0x00100000~0x00BFFFFF)</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_DMA_FLASH_SADDR</name><description>DMA Flash start address</description><addressOffset>0x0248</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dma_flash_saddr</name><description>DMA Flash start address</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_DMA_LEN</name><description>DMA transfer length</description><addressOffset>0x024C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dma_len</name><description>DMA length (n+1 bytes)</description><bitRange>[29:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>BUS_DMA_AHB_CTRL</name><description>DMA AHB burst control</description><addressOffset>0x0250</addressOffset><resetValue>0x00000007</resetValue><fields><field><name>incr4_en</name><description>INCR4 burst enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>incr8_en</name><description>INCR8 burst enable</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>incr16_en</name><description>INCR16 burst enable</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CMD_CONFIG</name><description>Command operation config</description><addressOffset>0x0300</addressOffset><resetValue>0x00007E00</resetValue><fields><field><name>start</name><description>Command start (auto-clears)</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>sel_cs</name><description>Chip select: 0=CS0; 1=CS1</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>addr_en</name><description>Address present: 0=no; 1=yes</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>dummy_byte_cnt</name><description>Dummy bytes: 000=0; 001=1; etc.</description><bitRange>[6:4]</bitRange><access>read-write</access></field><field><name>data_en</name><description>Data present: 0=no; 1=yes</description><bitRange>[7:7]</bitRange><access>read-write</access></field><field><name>rw</name><description>Data direction: 0=write; 1=read</description><bitRange>[8:8]</bitRange><access>read-write</access></field><field><name>data_cnt</name><description>Data length (n+1 bytes)</description><bitRange>[14:9]</bitRange><access>read-write</access></field><field><name>mem_if_type</name><description>SPI interface type: 000=Standard; 001=Dual; 010=Dual-IO; 101=Quad-Input; 110=Quad-IO</description><bitRange>[19:17]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CMD_INS</name><description>Command instruction register</description><addressOffset>0x0308</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>reg_ins</name><description>Instruction code</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CMD_ADDR</name><description>Command address register</description><addressOffset>0x030C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cmd_addr</name><description>Operation address</description><bitRange>[29:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CMD_DATABUF_0</name><description>Command data buffer 0</description><addressOffset>0x0400</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cmd_databuf_0</name><description>Data buffer 0</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LEA_LP_EN</name><description>LEA control register</description><addressOffset>0x1300</addressOffset><resetValue>0x00000001</resetValue><fields><field><name>lea_lp_en</name><description>AES low power: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LEA_DFX_INFO</name><description>LEA DFX register</description><addressOffset>0x1304</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lea_dfx_info</name><description>AES DFX observation</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>LEA_IV_VLD</name><description>LEA IV valid register</description><addressOffset>0x1600</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lea_iv_vld</name><description>AES IV value valid (auto-clears after sync)</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- SPI0 / SPI_M0 (Base: 0x44020000) - v151                      -->
    <!-- ============================================================ -->
    <peripheral>
      <name>SPI0</name>
      <description>SPI0 master/slave controller (SSI v151)</description>
      <baseAddress>0x44020000</baseAddress>
      <interrupt><name>SPI_INT</name><value>43</value></interrupt>
      <registers>
        <register><name>SPI_ER</name><description>SPI enable register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>spi_en</name><description>SPI enable: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_CTRA</name><description>SPI control register 0</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>soe</name><description>Shift register loop test: 0=normal; 1=loopback</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>scph</name><description>Clock phase: 0=first edge sample; 1=second edge sample</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>scpol</name><description>Clock polarity: 0=low idle; 1=high idle</description><bitRange>[4:4]</bitRange><access>read-write</access></field><field><name>dfs32</name><description>Data frame size in 32-bit mode (0=4bit; up to 31=35bit)</description><bitRange>[17:13]</bitRange><access>read-write</access></field><field><name>trsm</name><description>Transfer mode: 00=TX/RX; 01=TX only; 10=RX only</description><bitRange>[19:18]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_CTRB</name><description>SPI control register 1 (master only)</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>ndf</name><description>Number of data frames (master TX only mode)</description><bitRange>[15:0]</bitRange><access>read-write</access></field><field><name>ssi_clk_stretch_en</name><description>Clock stretch enable</description><bitRange>[27:27]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_ENHCTL</name><description>Enhanced control register (Dual/Quad/Octal)</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>spi_dual_en</name><description>Dual SPI mode enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>spi_quad_en</name><description>Quad SPI mode enable</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>spi_oct_en</name><description>Octal SPI mode enable</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_BRS</name><description>Baud rate select register</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>clk_div</name><description>Clock divider (master): SCK = SSI_CLK / (2 * (1 + CLK_DIV))</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_DCR</name><description>DMA control register</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tdmae</name><description>TX DMA enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>rdmae</name><description>RX DMA enable</description><bitRange>[1:1]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_DRDL</name><description>DMA RX data level</description><addressOffset>0x1C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dma_rx_data_level</name><description>DMA RX FIFO threshold</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_DTDL</name><description>DMA TX data level</description><addressOffset>0x20</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dma_tx_data_level</name><description>DMA TX FIFO threshold</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_DR</name><description>Data register (FIFO read/write)</description><addressOffset>0x60</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dr</name><description>Write: push to TX FIFO; Read: pop from RX FIFO</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_RAINSR</name><description>Raw interrupt status register</description><addressOffset>0xBC</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>txe_irq</name><description>TX FIFO empty raw status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>txo_irq</name><description>TX FIFO overflow raw status</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>rxu_irq</name><description>RX FIFO underflow raw status</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>rxo_irq</name><description>RX FIFO overflow raw status</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>rxf_irq</name><description>RX FIFO full raw status</description><bitRange>[4:4]</bitRange><access>read-only</access></field><field><name>mst_irq</name><description>Multi-master contention raw status</description><bitRange>[5:5]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SPI_INSR</name><description>Interrupt status register (masked)</description><addressOffset>0xC0</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>txe_is</name><description>TX empty interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>txo_is</name><description>TX overflow interrupt status</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>rxu_is</name><description>RX underflow interrupt status</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>rxo_is</name><description>RX overflow interrupt status</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>rxf_is</name><description>RX full interrupt status</description><bitRange>[4:4]</bitRange><access>read-only</access></field><field><name>mst_is</name><description>Multi-master interrupt status</description><bitRange>[5:5]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SPI_INMAR</name><description>Interrupt mask register</description><addressOffset>0xC4</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>txe_im</name><description>TX empty interrupt mask</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>txo_im</name><description>TX overflow interrupt mask</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>rxu_im</name><description>RX underflow interrupt mask</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>rxo_im</name><description>RX overflow interrupt mask</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>rxf_im</name><description>RX full interrupt mask</description><bitRange>[4:4]</bitRange><access>read-write</access></field><field><name>mst_im</name><description>Multi-master interrupt mask</description><bitRange>[5:5]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_SLENR</name><description>Slave enable register (master only)</description><addressOffset>0xC8</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>slave_enable</name><description>Slave select enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_TWLR</name><description>TX FIFO threshold level</description><addressOffset>0xCC</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tx_fifo_threshold</name><description>TX FIFO threshold level</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_TLR</name><description>TX FIFO level register</description><addressOffset>0xD0</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tx_fifo_level</name><description>TX FIFO data level</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SPI_RWLR</name><description>RX FIFO threshold level</description><addressOffset>0xD8</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rx_fifo_threshold</name><description>RX FIFO threshold level</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPI_RLR</name><description>RX FIFO level register</description><addressOffset>0xDC</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rx_fifo_level</name><description>RX FIFO data level</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SPI_WSR</name><description>Status register</description><addressOffset>0xE4</addressOffset><resetValue>0x00000006</resetValue><fields><field><name>busy</name><description>SPI busy flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>txfnf</name><description>TX FIFO not full</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>txfe</name><description>TX FIFO empty</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>rxfne</name><description>RX FIFO not empty</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>rxfo</name><description>RX FIFO overflow</description><bitRange>[4:4]</bitRange><access>read-only</access></field><field><name>txfo</name><description>TX FIFO overflow</description><bitRange>[5:5]</bitRange><access>read-only</access></field><field><name>dcm</name><description>Data conflict mask</description><bitRange>[6:6]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SPI_ICR</name><description>Interrupt clear register</description><addressOffset>0xF8</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>txo_ic</name><description>TX overflow interrupt clear</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>rxu_ic</name><description>RX underflow interrupt clear</description><bitRange>[1:1]</bitRange><access>write-only</access></field><field><name>rxo_ic</name><description>RX overflow interrupt clear</description><bitRange>[2:2]</bitRange><access>write-only</access></field><field><name>mst_ic</name><description>Multi-master interrupt clear</description><bitRange>[3:3]</bitRange><access>write-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- SPI1 (QSPI_0) derived from SPI0 -->
    <peripheral derivedFrom="SPI0">
      <name>SPI1</name>
      <description>SPI1/QSPI controller (SSI v151)</description>
      <baseAddress>0x44021000</baseAddress>
      <interrupt><name>QSPI_INT</name><value>52</value></interrupt>
    </peripheral>

    <!-- ============================================================ -->
    <!-- I2S/SIO (Base: 0x44025000) - v151                            -->
    <!-- ============================================================ -->
    <peripheral>
      <name>I2S</name>
      <description>I2S/SIO synchronous audio interface (v151)</description>
      <baseAddress>0x44025000</baseAddress>
      <interrupt><name>I2S_INT</name><value>51</value></interrupt>
      <registers>
        <register><name>VERSION</name><description>Version and loopback register</description><addressOffset>0x3C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>version</name><description>IP version</description><bitRange>[7:0]</bitRange><access>read-only</access></field><field><name>loopback_mode</name><description>Loopback mode enable</description><bitRange>[8:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>MODE</name><description>I2S/PCM mode register</description><addressOffset>0x40</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>channels</name><description>Number of channels: 0=2ch; 1=4ch; 2=6ch; 3=8ch</description><bitRange>[1:0]</bitRange><access>read-write</access></field><field><name>clk_edge</name><description>Clock edge: 0=rising; 1=falling</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>master_slave</name><description>Mode: 0=slave; 1=master</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>pcm_mode</name><description>PCM mode: 0=I2S; 1=PCM</description><bitRange>[4:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>INTSTATUS</name><description>Interrupt status register</description><addressOffset>0x44</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rx_int</name><description>RX interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>tx_int</name><description>TX interrupt status</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>rx_overflow</name><description>RX overflow status</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>tx_underflow</name><description>TX underflow status</description><bitRange>[3:3]</bitRange><access>read-only</access></field></fields></register>
        <register><name>INTCLR</name><description>Interrupt clear register</description><addressOffset>0x48</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rx_int_clr</name><description>Clear RX interrupt</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>tx_int_clr</name><description>Clear TX interrupt</description><bitRange>[1:1]</bitRange><access>write-only</access></field><field><name>rx_overflow_clr</name><description>Clear RX overflow</description><bitRange>[2:2]</bitRange><access>write-only</access></field><field><name>tx_underflow_clr</name><description>Clear TX underflow</description><bitRange>[3:3]</bitRange><access>write-only</access></field></fields></register>
        <register><name>LEFT_TX</name><description>TX left channel data</description><addressOffset>0x4C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>left_tx_data</name><description>TX left channel data</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>RIGHT_TX</name><description>TX right channel data</description><addressOffset>0x50</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>right_tx_data</name><description>TX right channel data</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LEFT_RX</name><description>RX left channel data</description><addressOffset>0x54</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>left_rx_data</name><description>RX left channel data</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RIGHT_RX</name><description>RX right channel data</description><addressOffset>0x58</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>right_rx_data</name><description>RX right channel data</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>CT_SET</name><description>Control set register</description><addressOffset>0x5C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tx_en</name><description>TX enable set</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>rx_en</name><description>RX enable set</description><bitRange>[1:1]</bitRange><access>write-only</access></field><field><name>tx_rst</name><description>TX reset set</description><bitRange>[2:2]</bitRange><access>write-only</access></field><field><name>rx_rst</name><description>RX reset set</description><bitRange>[3:3]</bitRange><access>write-only</access></field><field><name>tx_intr_en</name><description>TX interrupt enable set</description><bitRange>[4:4]</bitRange><access>write-only</access></field><field><name>rx_intr_en</name><description>RX interrupt enable set</description><bitRange>[5:5]</bitRange><access>write-only</access></field><field><name>merge_en</name><description>Merge enable set</description><bitRange>[6:6]</bitRange><access>write-only</access></field></fields></register>
        <register><name>CT_CLR</name><description>Control clear register</description><addressOffset>0x60</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tx_en</name><description>TX enable clear</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>rx_en</name><description>RX enable clear</description><bitRange>[1:1]</bitRange><access>write-only</access></field><field><name>tx_intr_en</name><description>TX interrupt disable</description><bitRange>[4:4]</bitRange><access>write-only</access></field><field><name>rx_intr_en</name><description>RX interrupt disable</description><bitRange>[5:5]</bitRange><access>write-only</access></field><field><name>merge_en</name><description>Merge disable</description><bitRange>[6:6]</bitRange><access>write-only</access></field></fields></register>
        <register><name>FIFO_THRESHOLD</name><description>FIFO threshold register</description><addressOffset>0x64</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tx_threshold</name><description>TX FIFO threshold</description><bitRange>[7:0]</bitRange><access>read-write</access></field><field><name>rx_threshold</name><description>RX FIFO threshold</description><bitRange>[15:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>RX_STA</name><description>RX status register</description><addressOffset>0x68</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>left_depth</name><description>RX left FIFO depth</description><bitRange>[7:0]</bitRange><access>read-only</access></field><field><name>right_depth</name><description>RX right FIFO depth</description><bitRange>[15:8]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TX_STA</name><description>TX status register</description><addressOffset>0x6C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>left_depth</name><description>TX left FIFO depth</description><bitRange>[7:0]</bitRange><access>read-only</access></field><field><name>right_depth</name><description>TX right FIFO depth</description><bitRange>[15:8]</bitRange><access>read-only</access></field></fields></register>
        <register><name>DATA_WIDTH_SET</name><description>Data width register</description><addressOffset>0x78</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tx_mode</name><description>TX data width mode</description><bitRange>[2:0]</bitRange><access>read-write</access></field><field><name>rx_mode</name><description>RX data width mode</description><bitRange>[10:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SIGNED_EXT</name><description>Signed extension enable</description><addressOffset>0x84</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>signed_ext_en</name><description>Signed extension enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>INTMASK</name><description>Interrupt mask register</description><addressOffset>0x8C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rx_int_mask</name><description>RX interrupt mask</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>tx_int_mask</name><description>TX interrupt mask</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>rx_overflow_mask</name><description>RX overflow mask</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>tx_underflow_mask</name><description>TX underflow mask</description><bitRange>[3:3]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2S_CRG</name><description>I2S clock/reset generator</description><addressOffset>0x90</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>bclk_div</name><description>BCLK divider</description><bitRange>[7:0]</bitRange><access>read-write</access></field><field><name>clk_en</name><description>Clock enable</description><bitRange>[8:8]</bitRange><access>read-write</access></field><field><name>clk_sel</name><description>Clock source select</description><bitRange>[9:9]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2S_BCLK_DIV_NUM</name><description>BCLK divider number</description><addressOffset>0x94</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>bclk_div_num</name><description>BCLK divider number</description><bitRange>[6:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2S_FS_DIV_NUM</name><description>FS divider number</description><addressOffset>0x98</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>fs_div_num</name><description>FS divider number</description><bitRange>[9:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2S_FS_DIV_RATIO_NUM</name><description>FS divider ratio number</description><addressOffset>0x9C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>fs_div_ratio_num</name><description>FS divider ratio number</description><bitRange>[10:0]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

