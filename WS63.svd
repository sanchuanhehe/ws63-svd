      <interrupt><name>GPIO_INT2</name><value>35</value></interrupt>
    </peripheral>

    <!-- ============================================================ -->
    <!-- UART0 (Base: 0x44010000) - Template                         -->
    <!-- ============================================================ -->
    <peripheral>
      <name>UART0</name>
      <description>UART0 - Universal Asynchronous Receiver/Transmitter</description>
      <baseAddress>0x44010000</baseAddress>
      <interrupt><name>UART0_INT</name><value>53</value></interrupt>
      <registers>
        <register><name>INTR_ID</name><description>Interrupt ID register</description><addressOffset>0x00</addressOffset><size>16</size><resetValue>0x0001</resetValue><fields><field><name>intr_id</name><description>Interrupt ID: 0x0=modem status; 0x1=no interrupt; 0x2=THR empty; 0x4=rx data; 0x6=rx line status; 0x7=busy; 0xC=char timeout</description><bitRange>[3:0]</bitRange><access>read-only</access></field><field><name>fifo_en_s</name><description>FIFO enable status: 0=FIFO disabled; 1=FIFO enabled</description><bitRange>[4:4]</bitRange><access>read-only</access></field></fields></register>
        <register><name>DATA</name><description>Data register</description><addressOffset>0x04</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>data</name><description>Write: TX data; Read: RX data</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>UART_CTL</name><description>UART control register</description><addressOffset>0x08</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>div_en</name><description>Divider enable: 0=div accessible when not busy; 1=div accessible anytime</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>xbreak</name><description>Break control: 0=normal; 1=force TX to space</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>dlen</name><description>Data length: 00=5bit; 01=6bit; 10=7bit; 11=8bit</description><bitRange>[3:2]</bitRange><access>read-write</access></field><field><name>eps</name><description>Parity select: 0=odd; 1=even</description><bitRange>[4:4]</bitRange><access>read-write</access></field><field><name>pen</name><description>Parity enable: 0=disabled; 1=enabled</description><bitRange>[5:5]</bitRange><access>read-write</access></field><field><name>sps</name><description>Sticky parity: 0=disabled; 1=enabled</description><bitRange>[6:6]</bitRange><access>read-write</access></field><field><name>stp</name><description>Stop bits: 0=1bit; 1=1.5/2bit</description><bitRange>[7:7]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_H</name><description>Baud rate divider high byte</description><addressOffset>0x0C</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>div_h</name><description>Divider integer high 8 bits</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_L</name><description>Baud rate divider low byte</description><addressOffset>0x10</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>div_l</name><description>Divider integer low 8 bits</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_FRA</name><description>Baud rate divider fractional part</description><addressOffset>0x14</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>div_fra</name><description>Divider fractional part (divided by 2^6)</description><bitRange>[5:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>INTR_EN</name><description>Interrupt enable register</description><addressOffset>0x18</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>rece_line_stat_intr_en</name><description>RX line status interrupt enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>modem_intr_en</name><description>Modem status interrupt enable</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>rece_data_intr_en</name><description>RX data available interrupt enable</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>tran_em_intr_en</name><description>TX empty interrupt enable</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>ptim_en</name><description>Programmable THRE interrupt mode enable</description><bitRange>[4:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>INTR_STATUS</name><description>Interrupt status register</description><addressOffset>0x1C</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>busy_det_intr</name><description>Busy detect interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>modem_intr_status</name><description>Modem interrupt status</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>thre_intr_status</name><description>THR empty interrupt status</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>char_to_intr_status</name><description>Character timeout interrupt status</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>data_avail_intr_status</name><description>RX data available interrupt status</description><bitRange>[4:4]</bitRange><access>read-only</access></field><field><name>line_intr_status</name><description>RX line interrupt status</description><bitRange>[5:5]</bitRange><access>read-only</access></field></fields></register>
        <register><name>FIFO_CTL</name><description>FIFO control register</description><addressOffset>0x24</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>tx_empty_trig</name><description>TX empty trigger: 00=empty; 01=2chars; 10=1/4; 11=1/2</description><bitRange>[1:0]</bitRange><access>write-only</access></field><field><name>rx_empty_trig</name><description>RX trigger: 00=1char; 01=1/4; 10=1/2; 11=2below full</description><bitRange>[3:2]</bitRange><access>write-only</access></field><field><name>fifo_en</name><description>FIFO enable</description><bitRange>[4:4]</bitRange><access>write-only</access></field><field><name>tx_fifo_rst</name><description>TX FIFO reset: 0=no reset; 1=reset</description><bitRange>[5:5]</bitRange><access>write-only</access></field><field><name>rx_fifo_rst</name><description>RX FIFO reset: 0=no reset; 1=reset</description><bitRange>[6:6]</bitRange><access>write-only</access></field></fields></register>
        <register><name>FAR</name><description>FIFO access mode enable register</description><addressOffset>0x28</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>far</name><description>FIFO access mode: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>MODEM_CTL</name><description>Modem control register</description><addressOffset>0x2C</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>afc_en</name><description>Auto flow control enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>lb_mode</name><description>Loopback mode: 0=disabled; 1=enabled</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>rts</name><description>RTS software control</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>MODEM_STATUS</name><description>Modem status register</description><addressOffset>0x30</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>dcts</name><description>CTS change indicator</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>cts</name><description>CTS signal state</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
        <register><name>LINE_STATUS</name><description>Line status register</description><addressOffset>0x34</addressOffset><size>16</size><resetValue>0x00C0</resetValue><fields><field><name>rx_fifo_err</name><description>RX FIFO error status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>frame_err</name><description>Framing error</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>parity_err</name><description>Parity error</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>overrun_err</name><description>Overrun error</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>break_intr</name><description>Break interrupt</description><bitRange>[4:4]</bitRange><access>read-only</access></field><field><name>data_available</name><description>Data available in RX FIFO/RBR</description><bitRange>[5:5]</bitRange><access>read-only</access></field><field><name>thre_s</name><description>THR empty flag</description><bitRange>[6:6]</bitRange><access>read-only</access></field><field><name>tx_empty_s</name><description>Transmitter empty flag</description><bitRange>[7:7]</bitRange><access>read-only</access></field></fields></register>
        <register><name>UART_GP_REG</name><description>UART general purpose register</description><addressOffset>0x38</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>uart_gp_reg</name><description>General purpose storage</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TX_FIFO_READ</name><description>TX FIFO read register</description><addressOffset>0x3C</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>tx_fifo_read</name><description>TX FIFO top data</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RX_FIFO_WRITE</name><description>RX FIFO write register</description><addressOffset>0x40</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>rx_fifo_write</name><description>Write: push data to RX FIFO; Read: rx_fifo_level[6:0]</description><bitRange>[7:0]</bitRange><access>read-write</access></field><field><name>rx_fifo_pe</name><description>RX FIFO parity error</description><bitRange>[8:8]</bitRange><access>write-only</access></field><field><name>rx_fifo_fe</name><description>RX FIFO framing error</description><bitRange>[9:9]</bitRange><access>write-only</access></field></fields></register>
        <register><name>FIFO_STATUS</name><description>FIFO status register</description><addressOffset>0x44</addressOffset><size>16</size><resetValue>0x0002</resetValue><fields><field><name>tx_fifo_full</name><description>TX FIFO full flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>tx_fifo_empty</name><description>TX FIFO empty flag</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>rx_fifo_full</name><description>RX FIFO full flag</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>rx_fifo_empty</name><description>RX FIFO empty flag</description><bitRange>[3:3]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TX_FIFO_CNT</name><description>TX FIFO data counter</description><addressOffset>0x48</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>tx_fifo_level</name><description>TX FIFO data count</description><bitRange>[6:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RX_FIFO_CNT</name><description>RX FIFO data counter</description><addressOffset>0x4C</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>reserved</name><description>Reserved</description><bitRange>[6:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>HALT_TX</name><description>TX halt register</description><addressOffset>0x50</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>halt_tx</name><description>TX halt: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DMA_SW_ACK</name><description>DMA software acknowledge register</description><addressOffset>0x54</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>dma_sw_ack</name><description>DMA software acknowledge (write-clear)</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>BAUD_CTL</name><description>Baud rate control register</description><addressOffset>0x58</addressOffset><size>16</size><resetValue>0x007F</resetValue><fields><field><name>baud_div</name><description>Baud rate oversampling: 0x7=8x; 0xF=16x</description><bitRange>[3:0]</bitRange><access>read-write</access></field><field><name>sample_phase</name><description>RX sample phase</description><bitRange>[7:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>STP_CTL</name><description>Stop bit control register</description><addressOffset>0x5C</addressOffset><size>16</size><resetValue>0x0000</resetValue><fields><field><name>rx_sp</name><description>RX stop bits when stp_mode=1</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>tx_sp</name><description>TX stop bits when stp_mode=1</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>stp_mode</name><description>Stop bit control mode: 0=UART_CTL stp; 1=STP_CTL</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>UART_PARAMETER</name><description>UART parameter register</description><addressOffset>0x60</addressOffset><size>16</size><resetValue>0x0D04</resetValue><fields><field><name>fifo_depth</name><description>FIFO depth: 0x4=64</description><bitRange>[7:0]</bitRange><access>read-only</access></field><field><name>apb_data_width</name><description>APB data width: 0x1=16bit</description><bitRange>[9:8]</bitRange><access>read-only</access></field><field><name>afce_mode</name><description>AFCE mode: 0=disabled; 1=enabled</description><bitRange>[10:10]</bitRange><access>read-only</access></field><field><name>dma_mode</name><description>DMA mode: 0=DMA_EXTRA disabled; 1=enabled</description><bitRange>[11:11]</bitRange><access>read-only</access></field><field><name>shadow</name><description>Shadow feature enable</description><bitRange>[12:12]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- UART1 derived from UART0 -->
    <peripheral derivedFrom="UART0">
      <name>UART1</name>
      <description>UART1 with flow control support</description>
      <baseAddress>0x44011000</baseAddress>
      <interrupt><name>UART1_INT</name><value>54</value></interrupt>
    </peripheral>

