      <registers>
        <register><name>LSADC_CTRL_0</name><description>ADC control register 0</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lsadc_ctrl_0</name><description>ADC control 0 configuration</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LSADC_CTRL_1</name><description>ADC control register 1</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>equ_model_sel</name><description>Equal model select (6-bit)</description><bitRange>[6:1]</bitRange><access>read-write</access></field><field><name>sample_cnt</name><description>Sample count</description><bitRange>[11:8]</bitRange><access>read-write</access></field><field><name>start_cnt</name><description>Start count</description><bitRange>[19:16]</bitRange><access>read-write</access></field><field><name>cast_cnt</name><description>Cast count</description><bitRange>[27:24]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LSADC_CTRL_2</name><description>ADC control register 2</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lsadc_ctrl_2</name><description>ADC control 2 configuration</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LSADC_CTRL_3</name><description>ADC control register 3</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lsadc_ctrl_3</name><description>ADC control 3 configuration</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LSADC_CTRL_4</name><description>ADC control register 4</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lsadc_ctrl_4</name><description>ADC control 4 configuration</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LSADC_CTRL_6</name><description>ADC scan start/stop register</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>lsadc_start</name><description>Start ADC scan: 1=start</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>lsadc_stop</name><description>Stop ADC scan: 1=stop</description><bitRange>[1:1]</bitRange><access>write-only</access></field></fields></register>
        <register><name>LSADC_CTRL_7</name><description>ADC enable register</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>da_lsadc_rstn</name><description>ADC reset (active low)</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>da_lsadc_en</name><description>ADC enable (16-bit, one per channel)</description><bitRange>[31:16]</bitRange><access>read-write</access></field></fields></register>
        <register><name>LSADC_FIFO_DATA</name><description>ADC FIFO data register</description><addressOffset>0x100</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data</name><description>ADC conversion data (14-bit)</description><bitRange>[13:0]</bitRange><access>read-only</access></field><field><name>channel</name><description>Channel number (3-bit)</description><bitRange>[16:14]</bitRange><access>read-only</access></field></fields></register>
        <register><name>CFG_CIC_FILTER_EN</name><description>CIC filter enable register</description><addressOffset>0x200</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cic_filter_en</name><description>CIC filter enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CFG_CIC_OSR</name><description>CIC oversampling ratio register</description><addressOffset>0x204</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>cic_osr</name><description>CIC oversampling ratio</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CFG_DATA_SEL</name><description>Data select register</description><addressOffset>0x208</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data_sel</name><description>Data output select</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CFG_OFFSET</name><description>Offset register</description><addressOffset>0x20C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>offset</name><description>ADC offset correction</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CFG_GAIN</name><description>Gain register</description><addressOffset>0x210</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gain</name><description>ADC gain correction</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- TSENSOR (Base: 0x4400E000) - v151                            -->
    <!-- ============================================================ -->
    <peripheral>
      <name>TSENSOR</name>
      <description>Temperature sensor controller (v151)</description>
      <baseAddress>0x4400E000</baseAddress>
      <interrupt><name>TSENSOR_INT</name><value>48</value></interrupt>
      <registers>
        <register><name>TSENSOR_CTL_ID</name><description>Temperature sensor control ID</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_ctl_id</name><description>Control ID</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TSENSOR_REG0</name><description>Common register 0</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_reg0</name><description>Common configuration register 0</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_REG1</name><description>Common register 1</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_reg1</name><description>Common configuration register 1</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_REG2</name><description>Common register 2</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_reg2</name><description>Common configuration register 2</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_REG3</name><description>Common register 3</description><addressOffset>0x1C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_reg3</name><description>Common configuration register 3</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_START</name><description>Temperature sensor start register</description><addressOffset>0x300</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_start</name><description>Write 1 to refresh temperature reading</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>TSENSOR_CTRL</name><description>Temperature sensor control register</description><addressOffset>0x304</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>tsensor_enable</name><description>Temperature sensor enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>tsensor_mode</name><description>Temperature sensor mode</description><bitRange>[2:1]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_STS</name><description>Temperature sensor status register</description><addressOffset>0x308</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>clr</name><description>Clear status</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>rdy</name><description>Data ready flag</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>data</name><description>Temperature code (10-bit, range 114-896 for -40C to 125C)</description><bitRange>[11:2]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TSENSOR_CTRL1</name><description>Temperature sensor control 1</description><addressOffset>0x310</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>temp_calib</name><description>Temperature calibration enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>temp_ct_sel</name><description>Temperature CT select</description><bitRange>[2:1]</bitRange><access>read-write</access></field><field><name>dft</name><description>DFT mode enable</description><bitRange>[4:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_TEMP_HIGH_LIMIT</name><description>High temperature limit</description><addressOffset>0x314</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>temp_high_limit</name><description>High temperature threshold (10-bit code)</description><bitRange>[9:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_TEMP_LOW_LIMIT</name><description>Low temperature limit</description><addressOffset>0x318</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>temp_low_limit</name><description>Low temperature threshold (10-bit code)</description><bitRange>[9:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_OVER_TEMP</name><description>Over-temperature threshold</description><addressOffset>0x31C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>over_temp</name><description>Over-temperature threshold (10-bit code)</description><bitRange>[9:0]</bitRange><access>read-write</access></field><field><name>over_temp_en</name><description>Over-temperature interrupt enable</description><bitRange>[10:10]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_TEMP_INT_EN</name><description>Temperature interrupt enable</description><addressOffset>0x320</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>done_int_en</name><description>Conversion done interrupt enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>out_thresh_int_en</name><description>Out-of-threshold interrupt enable</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>overtemp_int_en</name><description>Over-temperature interrupt enable</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_TEMP_INT_CLR</name><description>Temperature interrupt clear</description><addressOffset>0x324</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>done_int_clr</name><description>Clear done interrupt</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>out_thresh_int_clr</name><description>Clear out-of-threshold interrupt</description><bitRange>[1:1]</bitRange><access>write-only</access></field><field><name>overtemp_int_clr</name><description>Clear over-temperature interrupt</description><bitRange>[2:2]</bitRange><access>write-only</access></field></fields></register>
        <register><name>TSENSOR_TEMP_INT_STS</name><description>Temperature interrupt status</description><addressOffset>0x328</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>done_int_sts</name><description>Conversion done interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>out_thresh_int_sts</name><description>Out-of-threshold interrupt status</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>overtemp_int_sts</name><description>Over-temperature interrupt status</description><bitRange>[2:2]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TSENSOR_AUTO_REFRESH_PERIOD</name><description>Auto refresh period</description><addressOffset>0x330</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>auto_refresh_period</name><description>Auto refresh period in 32kHz clock cycles</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TSENSOR_AUTO_REFRESH_CFG</name><description>Auto refresh configuration</description><addressOffset>0x334</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>auto_refresh_en</name><description>Auto refresh enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- Timer (Base: 0x44002000) - v150                               -->
    <!-- ============================================================ -->
    <peripheral>
      <name>TIMER</name>
      <description>Timer module with 3 independent 32-bit timers (v150)</description>
      <baseAddress>0x44002000</baseAddress>
      <registers>
        <!-- Common timer registers -->
        <register><name>ABNOR_INTR_RAW</name><description>Abnormal interrupt raw status</description><addressOffset>0x60</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>abnor_intr_raw</name><description>Abnormal interrupt raw status for all timers</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>ABNOR_IMSK</name><description>Abnormal interrupt mask</description><addressOffset>0x64</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>abnor_imsk</name><description>Abnormal interrupt mask for all timers</description><bitRange>[2:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>ABNOR_INTR_STAT</name><description>Abnormal interrupt status</description><addressOffset>0x68</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>abnor_intr_stat</name><description>Abnormal interrupt status for all timers</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>EOI_REN</name><description>End-of-interrupt register</description><addressOffset>0x78</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>eoi</name><description>Clear interrupts for all timers (read to clear)</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RAW_INTR_STAT</name><description>Raw interrupt status</description><addressOffset>0x7C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>raw_intr</name><description>Raw interrupt status for all timers</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>INTR_STAT</name><description>Interrupt status (masked)</description><addressOffset>0x80</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>intr_stat</name><description>Interrupt status for all timers (after mask)</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>

        <!-- Timer 0 -->
        <register><name>TIMER0_LOAD_COUNT</name><description>Timer 0 load count</description><addressOffset>0x100</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>load_count</name><description>Timer 0 load count value</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TIMER0_CURRENT_VALUE</name><description>Timer 0 current value</description><addressOffset>0x108</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>current_value</name><description>Timer 0 current count value</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TIMER0_CONTROL</name><description>Timer 0 control register</description><addressOffset>0x110</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>enable</name><description>Timer enable: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>mode</name><description>Timer mode: 00=free running; 01=one-shot; 10=periodic</description><bitRange>[2:1]</bitRange><access>read-write</access></field><field><name>int_mask</name><description>Interrupt mask: 0=unmasked; 1=masked</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>rstfsm</name><description>Reset FSM: 1=reset timer FSM</description><bitRange>[4:4]</bitRange><access>write-only</access></field></fields></register>
        <register><name>TIMER0_EOI</name><description>Timer 0 end-of-interrupt</description><addressOffset>0x114</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>eoi</name><description>Read to clear timer 0 interrupt</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TIMER0_RAW_INTR</name><description>Timer 0 raw interrupt status</description><addressOffset>0x118</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>raw_intr</name><description>Raw interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>

        <!-- Timer 1 -->
        <register><name>TIMER1_LOAD_COUNT</name><description>Timer 1 load count</description><addressOffset>0x200</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>load_count</name><description>Timer 1 load count value</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TIMER1_CURRENT_VALUE</name><description>Timer 1 current value</description><addressOffset>0x208</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>current_value</name><description>Timer 1 current count value</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TIMER1_CONTROL</name><description>Timer 1 control register</description><addressOffset>0x210</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>enable</name><description>Timer enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>mode</name><description>Timer mode</description><bitRange>[2:1]</bitRange><access>read-write</access></field><field><name>int_mask</name><description>Interrupt mask</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>rstfsm</name><description>Reset FSM</description><bitRange>[4:4]</bitRange><access>write-only</access></field></fields></register>
        <register><name>TIMER1_EOI</name><description>Timer 1 end-of-interrupt</description><addressOffset>0x214</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>eoi</name><description>Read to clear timer 1 interrupt</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TIMER1_RAW_INTR</name><description>Timer 1 raw interrupt status</description><addressOffset>0x218</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>raw_intr</name><description>Raw interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>

        <!-- Timer 2 -->
        <register><name>TIMER2_LOAD_COUNT</name><description>Timer 2 load count</description><addressOffset>0x300</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>load_count</name><description>Timer 2 load count value</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TIMER2_CURRENT_VALUE</name><description>Timer 2 current value</description><addressOffset>0x308</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>current_value</name><description>Timer 2 current count value</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TIMER2_CONTROL</name><description>Timer 2 control register</description><addressOffset>0x310</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>enable</name><description>Timer enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>mode</name><description>Timer mode</description><bitRange>[2:1]</bitRange><access>read-write</access></field><field><name>int_mask</name><description>Interrupt mask</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>rstfsm</name><description>Reset FSM</description><bitRange>[4:4]</bitRange><access>write-only</access></field></fields></register>
        <register><name>TIMER2_EOI</name><description>Timer 2 end-of-interrupt</description><addressOffset>0x314</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>eoi</name><description>Read to clear timer 2 interrupt</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TIMER2_RAW_INTR</name><description>Timer 2 raw interrupt status</description><addressOffset>0x318</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>raw_intr</name><description>Raw interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- WDT (Base: 0x40006000) - v151                                 -->
    <!-- ============================================================ -->
    <peripheral>
      <name>WDT</name>
      <description>Watchdog timer (v151)</description>
      <baseAddress>0x40006000</baseAddress>
      <registers>
        <register><name>WDT_LOCK</name><description>Watchdog lock register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_lock</name><description>Write 0x5A5A5A5A to unlock, other values lock</description><bitRange>[31:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>WDT_LOAD</name><description>Watchdog load value</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_load</name><description>Load count value (24-bit, low 8 bits reserved)</description><bitRange>[31:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>WDT_RESTART</name><description>Watchdog restart register</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_restart</name><description>Write anything except 0x5A5A5A5A to restart counter</description><bitRange>[31:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>WDT_EOI</name><description>Watchdog interrupt clear (read to clear)</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_eoi</name><description>Read to clear watchdog interrupt</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>WDT_CR</name><description>Watchdog control register</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_en</name><description>Watchdog enable: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>rst_en</name><description>Reset enable: 0=no reset on timeout; 1=reset on timeout</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>rst_pl</name><description>Reset pulse length: 000=2 clocks; up to 111=256 clocks</description><bitRange>[5:3]</bitRange><access>read-write</access></field><field><name>wdt_imsk</name><description>Interrupt mask: 0=unmasked; 1=masked</description><bitRange>[6:6]</bitRange><access>read-write</access></field><field><name>wdt_mode</name><description>Mode: 0=one interrupt then reset; 1=two interrupts then reset</description><bitRange>[7:7]</bitRange><access>read-write</access></field></fields></register>
        <register><name>WDT_CNT</name><description>Watchdog current counter value</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_cnt</name><description>Current counter value</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>WDT_RAW_INTR</name><description>Watchdog raw interrupt status</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_raw_intr</name><description>Raw interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>WDT_INTR</name><description>Watchdog interrupt status (masked)</description><addressOffset>0x1C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_intr</name><description>Interrupt status after mask</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>WDT_LPIF_STATE</name><description>Watchdog low power state</description><addressOffset>0x20</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_lpif_state</name><description>Low power interface state</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>WDT_STATUS</name><description>Watchdog status</description><addressOffset>0x24</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_status</name><description>Status: 0=busy; 1=free</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>WDT_CCVR_EN</name><description>Watchdog counter value request</description><addressOffset>0x28</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>ccvr_req</name><description>Write 1 to request current counter value</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>ccvr_ack</name><description>Acknowledge: 1=counter value valid</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- RTC (Base: 0x57024000) - v100                                 -->
    <!-- ============================================================ -->
    <peripheral>
      <name>RTC</name>
      <description>Real-time clock (48-bit free-running counter, v100)</description>
      <baseAddress>0x57024000</baseAddress>
      <interrupt><name>RTC_IRQ</name><value>29</value></interrupt>
      <registers>
        <register><name>RTC_LOAD_COUNT</name><description>RTC load count register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>load_count</name><description>Load count value (threshold for interrupt)</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>RTC_CURRENT_VALUE</name><description>RTC current count value</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>current_value</name><description>Current counter value</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RTC_CONTROL</name><description>RTC control register</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>enable</name><description>RTC enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>mode</name><description>Mode: 0=free running; 1=periodic</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>int_mask</name><description>Interrupt mask: 0=unmasked; 1=masked</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>RTC_EOI</name><description>RTC end-of-interrupt (read to clear)</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>eoi</name><description>Read to clear RTC interrupt</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RTC_INT_STATUS</name><description>RTC interrupt status</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>int_status</name><description>Interrupt status</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- EFUSE (Base: 0x44008000) - v151                               -->
    <!-- ============================================================ -->
    <peripheral>
      <name>EFUSE</name>
      <description>eFuse controller (OTP, v151)</description>
      <baseAddress>0x44008000</baseAddress>
      <registers>
        <register><name>EFUSE_CTL_DATA</name><description>eFuse control data register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>efuse_ctl</name><description>eFuse control data</description><bitRange>[15:0]</bitRange><access>read-write</access></field><field><name>wr_rd</name><description>Write/Read control: 0=read; 1=write</description><bitRange>[16:16]</bitRange><access>read-write</access></field></fields></register>
        <register><name>EFUSE_CLK_PERIOD</name><description>eFuse clock period register</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>clk_period</name><description>Clock period value</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>EFUSE_AVDD_CTL</name><description>eFuse AVDD switch register</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>avdd_ctl</name><description>AVDD switch control</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>EFUSE_STS</name><description>eFuse status register (at offset 0x2C)</description><addressOffset>0x2C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>man_sts</name><description>Manufacturing status</description><bitRange>[1:0]</bitRange><access>read-only</access></field><field><name>boot0_done</name><description>Boot0 done flag</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>boot1_done</name><description>Boot1 done flag</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>boot2_done</name><description>Boot2 done flag</description><bitRange>[4:4]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- SYS_CTL0 (Base: 0x40000000) - System Control                 -->
    <!-- ============================================================ -->
    <peripheral>
      <name>SYS_CTL0</name>
      <description>System Control 0 - reset status, clock control, PLL config</description>
      <baseAddress>0x40000000</baseAddress>
      <registers>
        <register><name>RESET_COUNT</name><description>Reset count register</description><addressOffset>0x0008</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>reset_count</name><description>Reset count value</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>HW_CTL</name><description>Hardware control register</description><addressOffset>0x0014</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>refclk_freq_status</name><description>REFCLK frequency status: 0=40MHz; 1=24MHz</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>REG_SYS_RST_RECORD</name><description>System reset record register</description><addressOffset>0x0098</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_rst</name><description>Watchdog reset record</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>soft_rst</name><description>Software reset record</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>hard_rst</name><description>Hardware reset record</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SYS_RST_RECORD_0</name><description>System reset history record 0</description><addressOffset>0x00A0</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sys_wdt_rst_his</name><description>WDT reset history</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>sys_soft_rst_his</name><description>Software reset history</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>por_rst_filter_his</name><description>POR reset filter history</description><bitRange>[3:3]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SYS_DIAG_CLR_1</name><description>System diagnostic clear 1</description><addressOffset>0x00A4</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sys_diag_clr</name><description>Write to clear reset history bits</description><bitRange>[31:0]</bitRange><access>write-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- GLB_CTL_M (Base: 0x40002000) - Main Core Global Control       -->
    <!-- ============================================================ -->
    <peripheral>
      <name>GLB_CTL_M</name>
      <description>Main core global control - BCPU/MCPU reset status, chip reset, AON CRG</description>
      <baseAddress>0x40002000</baseAddress>
      <registers>
        <register><name>BCPU_RESET_STS</name><description>BCPU reset status register</description><addressOffset>0x0030</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>bcpu_reset_sts</name><description>BCPU reset status</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>MCPU_RESET_STS</name><description>MCPU reset status register</description><addressOffset>0x0034</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>mcpu_reset_sts</name><description>MCPU reset status</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>RESET_STS_CLEAR</name><description>Reset status clear register</description><addressOffset>0x003C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rst_sts_clear</name><description>Write 0xFF to clear all reset status bits</description><bitRange>[31:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>AON_CRG_CKEN_CTL</name><description>AON CRG clock enable control</description><addressOffset>0x0100</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_gate</name><description>WDT clock gate control at bit[4]</description><bitRange>[4:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>CHIP_RESET</name><description>Chip reset control register</description><addressOffset>0x0110</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>chip_reset_en</name><description>Chip reset enable: 1=assert chip reset</description><bitRange>[2:2]</bitRange><access>read-write</access></field></fields></register>
        <register><name>AON_SOFT_RST_CTL</name><description>AON soft reset control</description><addressOffset>0x0110</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>wdt_soft_rst</name><description>WDT soft reset at bit[1]</description><bitRange>[1:1]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- SPACC: Security Accelerator (Base: 0x44100000)               -->
    <!-- ============================================================ -->
    <peripheral>
      <name>SPACC</name>
      <description>Security accelerator - AES/SM4/LEA/TDES symmetric crypto, HASH/HMAC</description>
      <baseAddress>0x44100000</baseAddress>
      <interrupt><name>SPACC_REE_INT</name><value>64</value></interrupt>
      <registers>
        <register><name>SPACC_IE</name><description>SPACC interrupt enable</description><addressOffset>0x0004</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>spacc_ie_ree</name><description>REE interrupt enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>spacc_ie_tee</name><description>TEE interrupt enable</description><bitRange>[4:4]</bitRange><access>read-write</access></field><field><name>spacc_ie_hpp</name><description>HPP interrupt enable</description><bitRange>[8:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPACC_INT_RAW_SYM_CLR_FINISH</name><description>Sym clear finish raw interrupt</description><addressOffset>0x0008</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>raw_sym_clr_finish_int</name><description>Raw interrupt for sym clear finish</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>SPACC_SYM_CHN_LOCK</name><description>Sym channel lock register</description><addressOffset>0x0020</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sym_chn_lock</name><description>Symmetric channel lock status</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPACC_HASH_CHN_LOCK</name><description>Hash channel lock register</description><addressOffset>0x0040</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>hash_chn_lock</name><description>Hash channel lock status</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SPACC_SYM_CHN_CLEAR_REQ</name><description>Sym channel clear request</description><addressOffset>0x0060</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sym_chn_clear_req</name><description>Clear request for symmetric channels</description><bitRange>[31:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>SPACC_HASH_CHN_CLEAR_REQ</name><description>Hash channel clear request</description><addressOffset>0x0068</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>hash_chn_clear_req</name><description>Clear request for hash channels</description><bitRange>[31:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>SPACC_BUS_ERR</name><description>Bus error register</description><addressOffset>0x0200</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>bus_err</name><description>Bus error status</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <!-- Sym crypto channel registers -->
        <register><name>IN_SYM_CHN0_CTRL</name><description>Sym channel 0 control register (no-DMA mode)</description><addressOffset>0x4000</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sym_chn0_req</name><description>Channel 0 start request</description><bitRange>[31:31]</bitRange><access>write-only</access></field></fields></register>
        <register><name>IN_SYM_CHN0_KEY_CTRL</name><description>Sym channel 0 key control (no-DMA mode)</description><addressOffset>0x4010</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>key_chn_id</name><description>Key channel ID</description><bitRange>[8:0]</bitRange><access>read-write</access></field><field><name>alg_sel</name><description>Algorithm: 2=AES; 4=LEA; 5=SM4; 6=GHASH; 7=TDES</description><bitRange>[19:16]</bitRange><access>read-write</access></field><field><name>alg_mode</name><description>Mode: 1=ECB; 3=CBC; 6=CTR; 0xA=GCM; 0xC=CMAC</description><bitRange>[23:20]</bitRange><access>read-write</access></field><field><name>key_len</name><description>Key length: 0=128bit; 1=192bit; 2=256bit</description><bitRange>[25:24]</bitRange><access>read-write</access></field><field><name>data_width</name><description>Data width: 0=128bit; 1=64bit; 2=32bit</description><bitRange>[27:26]</bitRange><access>read-write</access></field><field><name>decrypt</name><description>Decrypt: 0=encrypt; 1=decrypt</description><bitRange>[28:28]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_SPECIAL_CTRL</name><description>Sym channel 0 special control</description><addressOffset>0x4004</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sym_chn0_odd_even</name><description>Odd/even control for TDES</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_IV_DATA_CTRL</name><description>Sym channel 0 IV/data control (register mode)</description><addressOffset>0x4030</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>first_block</name><description>First block flag</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>last_block</name><description>Last block flag</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>block_len</name><description>Block length (in bytes)</description><bitRange>[20:16]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_IV0</name><description>Sym channel 0 IV word 0 (register mode)</description><addressOffset>0x4040</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>iv0</name><description>IV[31:0]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_IV1</name><description>Sym channel 0 IV word 1</description><addressOffset>0x4044</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>iv1</name><description>IV[63:32]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_IV2</name><description>Sym channel 0 IV word 2</description><addressOffset>0x4048</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>iv2</name><description>IV[95:64]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_IV3</name><description>Sym channel 0 IV word 3</description><addressOffset>0x404C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>iv3</name><description>IV[127:96]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>IN_SYM_CHN0_DATA0</name><description>Sym channel 0 data word 0 (register mode)</description><addressOffset>0x4050</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data0</name><description>Input data[31:0]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>SYM_CHANN_RAW_INT</name><description>Sym channel raw interrupt status</description><addressOffset>0x8610</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>sym_chann_raw_int</name><description>Raw interrupt per channel [15:0]</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- PKE: Public Key Engine (Base: 0x44110000)                     -->
    <!-- ============================================================ -->
    <peripheral>
      <name>PKE</name>
      <description>Public Key Engine - modular arithmetic accelerator</description>
      <baseAddress>0x44110000</baseAddress>
      <interrupt><name>PKE_REE_INT</name><value>63</value></interrupt>
      <registers>
        <register><name>PKE_WORK_LEN</name><description>PKE work length register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>work_len</name><description>Operand bit length for modular arithmetic</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INSTR0</name><description>PKE instruction register 0</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>instr0</name><description>Instruction code 0 (0=MUL_MOD, 1=ADD_MOD, 2=SUB_MOD)</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INSTR1</name><description>PKE instruction register 1</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>instr1</name><description>Instruction code 1</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INSTR_ADDR_LOW</name><description>PKE instruction start address low</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>instr_addr_low</name><description>Instruction start address [31:0]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INSTR_ADDR_HIG</name><description>PKE instruction start address high</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>instr_addr_hig</name><description>Instruction start address high bits</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INSTR_LEN</name><description>PKE instruction length</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>instr_len</name><description>Total instruction length in bytes</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_MASK_RNG_CFG</name><description>PKE mask RNG configuration</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>mask_rng_cfg</name><description>Mask RNG enable: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_MONT_PARA0</name><description>PKE Montgomery parameter 0</description><addressOffset>0x20</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>mont_para0</name><description>Montgomery pre-computed parameter word 0</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_MONT_PARA1</name><description>PKE Montgomery parameter 1</description><addressOffset>0x24</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>mont_para1</name><description>Montgomery pre-computed parameter word 1</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_START</name><description>PKE start control register</description><addressOffset>0x40</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pke_start0</name><description>Start code 0 (write 0x5 to start)</description><bitRange>[3:0]</bitRange><access>write-only</access></field><field><name>pke_start1</name><description>Start code 1 (write 0xA)</description><bitRange>[7:4]</bitRange><access>write-only</access></field><field><name>pke_batch_start</name><description>Batch start code (write 0x5)</description><bitRange>[11:8]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PKE_INSTR_RDY</name><description>PKE instruction ready status</description><addressOffset>0x44</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>instr0_rdy</name><description>Instruction buffer 0 ready</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>instr1_rdy</name><description>Instruction buffer 1 ready</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>batch_instr_rdy</name><description>Batch instruction ready</description><bitRange>[2:2]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PKE_BUSY</name><description>PKE busy status register</description><addressOffset>0x48</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pke_busy</name><description>PKE busy: 0=idle; 1=busy</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PKE_NOISE_EN</name><description>PKE noise enable register</description><addressOffset>0x4C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>noise_en</name><description>Side-channel noise enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INT_ENABLE</name><description>PKE interrupt enable</description><addressOffset>0x80</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>finish_int_enable</name><description>Operation finish interrupt enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_INT_NOMASK_STATUS</name><description>PKE unmasked interrupt status</description><addressOffset>0x84</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>finish_int_nomask</name><description>Finish interrupt status (expect 0x5 after completion)</description><bitRange>[3:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PKE_ALARM_STATUS</name><description>PKE alarm status register</description><addressOffset>0x8C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>alarm_int</name><description>Security alarm interrupt</description><bitRange>[3:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PKE_FAILURE_FLAG</name><description>PKE failure flag register</description><addressOffset>0x90</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pke_failure_flag</name><description>Operation failure status</description><bitRange>[10:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PKE_DRAM_CLR</name><description>PKE DRAM clear register</description><addressOffset>0xC0</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dram_clr</name><description>Clear PKE DRAM</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PKE_LOCK_CTRL</name><description>PKE lock control register</description><addressOffset>0x810</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pke_lock</name><description>Lock request</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>pke_lock_type</name><description>Lock type: 0=soft; 1=hard</description><bitRange>[1:1]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PKE_LOCK_STATUS</name><description>PKE lock status register</description><addressOffset>0x814</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pke_lock_busy</name><description>Lock busy flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>pke_unlock_fail</name><description>Unlock failure flag</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>pke_lock_cnt</name><description>Lock count</description><bitRange>[6:4]</bitRange><access>read-only</access></field><field><name>pke_lock_stat</name><description>Lock status: 0x6A=PCPU; 0x35=AIDSP; 0xA5=TEE; 0xAA=ACPU</description><bitRange>[15:8]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- KM: Key Management (Base: 0x44112000)                       -->
    <!-- ============================================================ -->
    <peripheral>
      <name>KM</name>
      <description>Key Management - KLAD key derivation, keyslot locking, RKP root key protection</description>
      <baseAddress>0x44112000</baseAddress>
      <interrupt><name>KLAD_REE_INT</name><value>66</value></interrupt>
      <registers>
        <!-- KLAD registers -->
        <register><name>KL_DATA_IN_0</name><description>Key data input word 0</description><addressOffset>0x1000</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data</name><description>Key data[31:0]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_DATA_IN_1</name><description>Key data input word 1</description><addressOffset>0x1004</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data</name><description>Key data[63:32]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_DATA_IN_2</name><description>Key data input word 2</description><addressOffset>0x1008</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data</name><description>Key data[95:64]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_DATA_IN_3</name><description>Key data input word 3</description><addressOffset>0x100C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data</name><description>Key data[127:96]</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_KEY_ADDR</name><description>Key address register</description><addressOffset>0x1010</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>key_addr</name><description>Target key slot address</description><bitRange>[9:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_KEY_CFG</name><description>Key configuration register</description><addressOffset>0x1014</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>port_sel</name><description>Port select</description><bitRange>[2:0]</bitRange><access>read-write</access></field><field><name>dsc_code</name><description>Descriptor code</description><bitRange>[11:4]</bitRange><access>read-write</access></field><field><name>key_enc</name><description>Key encrypt enable</description><bitRange>[16:16]</bitRange><access>read-write</access></field><field><name>key_dec</name><description>Key decrypt enable</description><bitRange>[17:17]</bitRange><access>read-write</access></field><field><name>kl_flash_sel</name><description>Flash key source select</description><bitRange>[19:18]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_KEY_SEC_CFG</name><description>Key security configuration</description><addressOffset>0x1018</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>key_sec</name><description>Key security: 0=NS; 1=Secure</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>src_nsec</name><description>Source non-secure: 0=secure; 1=NS</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>src_sec</name><description>Source secure: 0=NS; 1=Secure</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>dest_nsec</name><description>Destination non-secure</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>dest_sec</name><description>Destination secure</description><bitRange>[4:4]</bitRange><access>read-write</access></field><field><name>master_only</name><description>Master-only access</description><bitRange>[5:5]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_STATE</name><description>KLAD state register</description><addressOffset>0x1030</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>state</name><description>KLAD processing state</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>KL_ERROR</name><description>KLAD error register</description><addressOffset>0x1038</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>error</name><description>KLAD error code</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>KL_INT_EN</name><description>KLAD interrupt enable</description><addressOffset>0x1040</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>kl_int_en</name><description>KLAD interrupt enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_INT</name><description>KLAD interrupt status</description><addressOffset>0x1048</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>kl_int</name><description>KLAD interrupt flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>KL_COM_CTRL</name><description>KLAD common control</description><addressOffset>0x1084</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>kl_com_start</name><description>Common KDF start</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>kl_com_level_sel</name><description>Level select</description><bitRange>[3:1]</bitRange><access>read-write</access></field><field><name>kl_com_alg_sel</name><description>Algorithm select</description><bitRange>[5:4]</bitRange><access>read-write</access></field><field><name>kl_com_key_size</name><description>Key size select</description><bitRange>[7:6]</bitRange><access>read-write</access></field><field><name>rk_choose</name><description>Root key select: 4=USD; 5=SBRK; 6=ABRK; 13=DRK; 18=PSK</description><bitRange>[12:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_COM_STATUS</name><description>KLAD common status</description><addressOffset>0x1088</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>kl_com_rk_rdy</name><description>Root key ready</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>kl_com_lv1_rdy</name><description>Level 1 key ready</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
        <register><name>KL_LOCK_CTRL</name><description>KLAD lock control</description><addressOffset>0x1074</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>kl_lock</name><description>Lock request</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>kl_lock_num</name><description>Lock sequence number</description><bitRange>[6:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>KL_ALARM_INFO</name><description>KLAD alarm info register</description><addressOffset>0x1600</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>kl_cfg_sig_alarm</name><description>Config signature alarm</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>kl_com_crc16_alarm</name><description>Common CRC16 alarm</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
        <!-- Keyslot registers -->
        <register><name>KC_TEECPU_LOCK_CMD</name><description>TEE CPU keyslot lock command</description><addressOffset>0x1B00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>key_slot_num</name><description>Key slot number</description><bitRange>[9:0]</bitRange><access>read-write</access></field><field><name>lock_cmd</name><description>Lock command: 0x01=REE; 0x10=TEE; 0x100=PCPU; 0x110=AIDSP</description><bitRange>[20:20]</bitRange><access>write-only</access></field></fields></register>
        <register><name>KC_RD_LOCK_STATUS</name><description>Keyslot lock status readback</description><addressOffset>0x1B34</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rd_lock_status</name><description>Lock status: 0=unlock; 1=REE; 2=TEE; 4=PCPU; 6=AIDSP</description><bitRange>[2:0]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- TRNG: True Random Number Generator (Base: 0x44114000)         -->
    <!-- ============================================================ -->
    <peripheral>
      <name>TRNG</name>
      <description>True Random Number Generator</description>
      <baseAddress>0x44114000</baseAddress>
      <registers>
        <register><name>TRNG_FIFO_DATA</name><description>TRNG FIFO data output register</description><addressOffset>0x0100</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>trng_data</name><description>Random data (read to get random number)</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TRNG_FIFO_READY</name><description>TRNG FIFO ready status</description><addressOffset>0x0104</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>trng_data_ready</name><description>Data ready: 1=data available in FIFO</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>trng_done</name><description>TRNG generation done</description><bitRange>[1:1]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TRNG_DATA_ST</name><description>TRNG data status register</description><addressOffset>0x0108</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>data_st</name><description>Data status</description><bitRange>[31:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TRNG_FRO_SAMPLE_CLK_SEL</name><description>TRNG FRO sample clock select</description><addressOffset>0x0174</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>fro_sample_clk_sel</name><description>FRO sample clock select: 0=inner; 1=external</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>TRNG_FRO_DIV_CNT</name><description>TRNG FRO divider count</description><addressOffset>0x0178</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>fro_div_cnt</name><description>FRO divider count (default 0x1b)</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- TCXO: Temperature-Compensated Crystal Oscillator Counter      -->
    <!-- Base: 0x440004C0 - v150                                       -->
    <!-- ============================================================ -->
    <peripheral>
      <name>TCXO</name>
      <description>TCXO 64-bit free-running counter (v150)</description>
      <baseAddress>0x440004C0</baseAddress>
      <registers>
        <register><name>TCXO_STATUS</name><description>TCXO status and control register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields>
          <field><name>valid</name><description>TCXO count value valid flag</description><bitRange>[4:4]</bitRange><access>read-only</access></field>
          <field><name>enable</name><description>TCXO count enable: 1=enable counting</description><bitRange>[2:2]</bitRange><access>read-write</access></field>
          <field><name>clear</name><description>TCXO count clear: 1=clear counter</description><bitRange>[1:1]</bitRange><access>read-write</access></field>
          <field><name>refresh</name><description>TCXO count refresh: 1=trigger count latch</description><bitRange>[0:0]</bitRange><access>read-write</access></field>
        </fields></register>
        <register><name>TCXO_COUNT0</name><description>TCXO count bits [15:0]</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>count0</name><description>Counter value bits [15:0]</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TCXO_COUNT1</name><description>TCXO count bits [31:16]</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>count1</name><description>Counter value bits [31:16]</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TCXO_COUNT2</name><description>TCXO count bits [47:32]</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>count2</name><description>Counter value bits [47:32]</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>TCXO_COUNT3</name><description>TCXO count bits [63:48]</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>count3</name><description>Counter value bits [63:48]</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- CLDO_CRG: Clock &amp; Reset Generator (Base: 0x44001100)       -->
    <!-- ============================================================ -->
    <peripheral>
      <name>CLDO_CRG</name>
      <description>CLDO Clock and Reset Generator - clock enables, dividers, clock selects, soft resets</description>
      <baseAddress>0x44001100</baseAddress>
      <registers>
        <register><name>CKEN_CTL0</name><description>Clock enable control register 0</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields>
          <field><name>pwm_cken</name><description>PWM clock gates: bits [10:2], 9 channels</description><bitRange>[10:2]</bitRange><access>read-write</access></field>
          <field><name>gen_cken</name><description>General clock gates: bits [27:18], 10 channels</description><bitRange>[27:18]</bitRange><access>read-write</access></field>
        </fields></register>
        <register><name>CKEN_CTL1</name><description>Clock enable control register 1</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields>
          <field><name>bt_cken</name><description>BT clock gates: bits [12:8], 5 channels</description><bitRange>[12:8]</bitRange><access>read-write</access></field>
          <field><name>wifi_cken</name><description>WIFI clock gates: bits [14:13], 2 channels</description><bitRange>[14:13]</bitRange><access>read-write</access></field>
          <field><name>uart_cken</name><description>UART clock gates: bits [20:18], 3 channels</description><bitRange>[20:18]</bitRange><access>read-write</access></field>
          <field><name>spi_cken</name><description>SPI clock gate at bit 25</description><bitRange>[25:25]</bitRange><access>read-write</access></field>
        </fields></register>
        <register><name>DIV_CTL0</name><description>Divider control register 0</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>div_ctl0</name><description>Clock divider control 0</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_CTL3</name><description>Divider control 3 - PWM0, PWM1</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>div_pwm01</name><description>PWM0/PWM1 clock divider</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_CTL4</name><description>Divider control 4 - PWM2, PWM3, PWM4</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>div_pwm234</name><description>PWM2/PWM3/PWM4 clock divider</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_CTL5</name><description>Divider control 5 - PWM5, PWM6, PWM7</description><addressOffset>0x1C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>div_pwm567</name><description>PWM5/PWM6/PWM7 clock divider</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_CTL7</name><description>Divider control 7 - tsensor, bus</description><addressOffset>0x24</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>div_tsensor_bus</name><description>TSENSOR and bus clock dividers</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_CTL9</name><description>Divider control 9 - TRNG</description><addressOffset>0x2C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>div_trng</name><description>TRNG clock divider</description><bitRange>[31:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DIV_CTL10</name><description>Divider control 10 - TCXO 120M, MAC main</description><addressOffset>0x30</addressOffset><resetValue>0x00000000</resetValue><fields>
          <field><name>tcxo_120m_div1_num</name><description>TCXO 120M divider 1 value (3-bit)</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          <field><name>tcxo_120m_load_div_en</name><description>TCXO 120M load divider enable</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
          <field><name>tcxo_120m_div_en</name><description>TCXO 120M divider enable</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
          <field><name>mac_main_div_num</name><description>MAC main divider value (6-bit)</description><bitRange>[10:5]</bitRange><access>read-write</access></field>
          <field><name>wtop_div_en</name><description>WTO divider enable</description><bitRange>[11:11]</bitRange><access>read-write</access></field>
          <field><name>tcxo_120m_div2_num</name><description>TCXO 120M divider 2 value (3-bit)</description><bitRange>[14:12]</bitRange><access>read-write</access></field>
        </fields></register>
        <register><name>CLK_SEL</name><description>Clock source select register</description><addressOffset>0x34</addressOffset><resetValue>0x00000000</resetValue><fields>
          <field><name>rf_ctl_clk_sel</name><description>RF_CTL clock: 0=TCXO; 1=PLL</description><bitRange>[0:0]</bitRange><access>read-write</access></field>
          <field><name>uart0_clk_sel</name><description>UART0 clock: 0=TCXO; 1=PLL</description><bitRange>[1:1]</bitRange><access>read-write</access></field>
          <field><name>uart1_clk_sel</name><description>UART1 clock select</description><bitRange>[2:2]</bitRange><access>read-write</access></field>
          <field><name>uart2_clk_sel</name><description>UART2 clock select</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
          <field><name>spi_clk_sel</name><description>SPI clock select</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
          <field><name>pwm_clk_sel</name><description>PWM clock: 0=TCXO; 1=PLL</description><bitRange>[7:7]</bitRange><access>read-write</access></field>
          <field><name>bus_clk_sel</name><description>Bus clock select</description><bitRange>[17:17]</bitRange><access>read-write</access></field>
          <field><name>flash_clk_sel</name><description>Flash clock: 0=TCXO; 1=PLL</description><bitRange>[18:18]</bitRange><access>read-write</access></field>
          <field><name>wifi_phy_clk_sel</name><description>WIFI_PHY clock select</description><bitRange>[19:19]</bitRange><access>read-write</access></field>
          <field><name>wifi_mac_clk_sel</name><description>WIFI_MAC clock select</description><bitRange>[20:20]</bitRange><access>read-write</access></field>
        </fields></register>
        <register><name>RST_SOFT_CFG0</name><description>Soft reset configuration register 0</description><addressOffset>0x38</addressOffset><resetValue>0x00000000</resetValue><fields>
          <field><name>cfg0_b3_b15</name><description>13-bit soft reset control (bits [15:3])</description><bitRange>[15:3]</bitRange><access>read-write</access></field>
          <field><name>cfg0_b17_b24</name><description>8-bit soft reset control (bits [24:17])</description><bitRange>[24:17]</bitRange><access>read-write</access></field>
          <field><name>cfg0_b27_b28</name><description>2-bit soft reset control (bits [28:27])</description><bitRange>[28:27]</bitRange><access>read-write</access></field>
          <field><name>cfg0_b30</name><description>Soft reset bit 30</description><bitRange>[30:30]</bitRange><access>read-write</access></field>
        </fields></register>
        <register><name>RST_SOFT_CFG1</name><description>Soft reset configuration register 1 (active low)</description><addressOffset>0x3C</addressOffset><resetValue>0xFFFFFFFF</resetValue><fields>
          <field><name>soft_rst_gpio_n</name><description>GPIO module reset: 0=reset; 1=released</description><bitRange>[0:0]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_tglp_n</name><description>TGLP (BT) reset: 0=reset; 1=released</description><bitRange>[1:1]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_bsub_n</name><description>BSUB (BT) reset: 0=reset; 1=released</description><bitRange>[2:2]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_crg_bsub_n</name><description>CRG BSUB (BT) reset: 0=reset; 1=released</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_wifi_n</name><description>WIFI subsystem reset: 0=reset; 1=released</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_lsadc_n</name><description>LSADC core reset: 0=reset; 1=released</description><bitRange>[5:5]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_tcxo_cnt_n</name><description>TCXO counter reset: 0=reset; 1=released</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_lsadc_bus_n</name><description>LSADC bus interface reset: 0=reset; 1=released</description><bitRange>[7:7]</bitRange><access>read-write</access></field>
          <field><name>soft_rst_wcpu_mem_ctl_n</name><description>WCPU memory controller reset: 0=reset; 1=released</description><bitRange>[8:8]</bitRange><access>read-write</access></field>
        </fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- SDMA: Secure DMA (Base: 0x520A0000) - v151                     -->
    <!-- ============================================================ -->
    <peripheral derivedFrom="DMA">
      <name>SDMA</name>
      <description>Secure DMA controller (4 channels, same layout as MDMA v151). Channels logically mapped as 8-11.</description>
      <baseAddress>0x520A0000</baseAddress>
    </peripheral>

    <!-- ============================================================ -->
    <!-- ULP_GPIO: Ultra-Low-Power GPIO (Base: 0x57030000)             -->
    <!-- ============================================================ -->
    <peripheral derivedFrom="GPIO0">
      <name>ULP_GPIO</name>
      <description>Ultra-low-power GPIO controller (8 pins, GPIO[107:114]). Same register layout as GPIO0.</description>
      <baseAddress>0x57030000</baseAddress>
    </peripheral>

    <!-- ============================================================ -->
    <!-- SYS_CTL2 sub-blocks: RF_WB_CTL, SHARE_MEM_CTL, FAMA_REMAP     -->
    <!-- All in range 0x44004000 - 0x44007FFF                           -->
    <!-- No bit-level definitions exist in SDK - registers listed as   -->
    <!-- named 32-bit registers for address discovery.                  -->
    <!-- ============================================================ -->

    <!-- RF_WB_CTL: RF Wideband Control (Base: 0x44004000) -->
    <peripheral>
      <name>RF_WB_CTL</name>
      <description>SYS_CTL2 sub-block: RF Wideband Control Register Block - WL/BT RF analog interface control</description>
      <baseAddress>0x44004000</baseAddress>
      <registers>
        <register><name>SYS_CTL_ID</name><description>System control ID register</description><addressOffset>0x000</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RF_WL_REG_CLK_CTL</name><description>RF WL register clock control</description><addressOffset>0x010</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RF_WL_REG_SOFT_RSTN</name><description>RF WL register soft reset</description><addressOffset>0x014</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RF_WL_REG_CMD_SOFT_RSTN</name><description>RF WL command soft reset</description><addressOffset>0x018</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RF_WL_REG_CMD_FIFO_STS</name><description>RF WL command FIFO status</description><addressOffset>0x01C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RF_WL_CBB_DIS</name><description>RF WL CBB disable</description><addressOffset>0x020</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RF_BT_CBB_DIS</name><description>RF BT CBB disable</description><addressOffset>0x024</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>ABB_ADC_CTRL</name><description>ABB ADC control</description><addressOffset>0x030</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>ABB_DAC_CTRL</name><description>ABB DAC control</description><addressOffset>0x034</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>ABB_EN_CTRL</name><description>ABB enable control</description><addressOffset>0x038</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_WL_ADC_MUX</name><description>WL ADC mux configuration</description><addressOffset>0x03C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RF_MAN_EN_CTRL</name><description>RF manual enable control</description><addressOffset>0x040</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TRXEN_CTRL</name><description>TRX enable control</description><addressOffset>0x044</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_DCOC_IQ_CTRL</name><description>DCOC IQ control</description><addressOffset>0x048</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_PA_IDX_CTRL</name><description>PA index control</description><addressOffset>0x04C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_LPF_CTRL</name><description>LPF control</description><addressOffset>0x050</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RADAR_CTRL</name><description>Radar control</description><addressOffset>0x054</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_PPA_CODE</name><description>PPA code register</description><addressOffset>0x058</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TEMP_LOCK_CTRL</name><description>Temperature lock control</description><addressOffset>0x05C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TEMP_BANK_SEL_CTRL</name><description>Temperature bank select control</description><addressOffset>0x060</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RF_DIAG_MUX</name><description>RF diagnostic mux</description><addressOffset>0x064</addressOffset><resetValue>0x00000000</resetValue></register>
      </registers>
    </peripheral>

    <!-- SHARE_MEM_CTL: Shared Memory Control (Base: 0x44006C00) -->
    <peripheral>
      <name>SHARE_MEM_CTL</name>
      <description>SYS_CTL2 sub-block: Shared Memory Control - RAM config, RX/TX DMA descriptor rings for WiFi PHY↔Packet buffer</description>
      <baseAddress>0x44006C00</baseAddress>
      <registers>
        <register><name>CFG_RAM_CKEN</name><description>RAM clock enable</description><addressOffset>0x004</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RAM_SEL</name><description>Share RAM control and RAM select</description><addressOffset>0x008</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RAM_SW_CONFLICT_CLR</name><description>RAM software conflict clear</description><addressOffset>0x00C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RAM_SW_CONFLICT_ST</name><description>RAM software conflict status</description><addressOffset>0x010</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>RAMX_SW_CONFLICT_BASE_ADDR</name><description>RAMX software conflict base address</description><addressOffset>0x014</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_FREQ_BUSDMAC</name><description>Bus DMAC frequency configuration</description><addressOffset>0x050</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RX_EN</name><description>RX enable</description><addressOffset>0x058</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RX_START_ADDR</name><description>RX start address</description><addressOffset>0x05C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RX_END_ADDR</name><description>RX end address</description><addressOffset>0x060</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RX_DONE_STS</name><description>RX done status</description><addressOffset>0x064</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_RX_DONE_ADDR</name><description>RX done address</description><addressOffset>0x068</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_WLPHY2PKT_RX_RAM_STS</name><description>WL PHY-to-packet RX RAM status</description><addressOffset>0x06C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TX_EN</name><description>TX enable</description><addressOffset>0x070</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TX_START_ADDR</name><description>TX start address</description><addressOffset>0x074</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TX_END_ADDR</name><description>TX end address</description><addressOffset>0x078</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TX_DONE_STS</name><description>TX done status</description><addressOffset>0x07C</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_TX_DONE_ADDR</name><description>TX done address</description><addressOffset>0x080</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>CFG_WLPHY2PKT_TX_RAM_STS</name><description>WL PHY-to-packet TX RAM status</description><addressOffset>0x084</addressOffset><resetValue>0x00000000</resetValue></register>
      </registers>
    </peripheral>

    <!-- FAMA_REMAP: Flash Address Remap (Base: 0x44007800) -->
    <peripheral>
      <name>FAMA_REMAP</name>
      <description>SYS_CTL2 sub-block: Flash Address Map Remap - up to 12 regions for boot-time address redirection</description>
      <baseAddress>0x44007800</baseAddress>
      <registers>
        <register><name>REMAP_SRC_BASE</name><description>Remap source base address (address >> 12). Up to 12 regions, offset 0x0 + 0x4*n</description><addressOffset>0x000</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>REMAP_LEN</name><description>Remap region length (end address >> 12). offset 0x20 + 0x4*n</description><addressOffset>0x020</addressOffset><resetValue>0x00000000</resetValue></register>
        <register><name>REMAP_DST_BASE</name><description>Remap destination base offset (dest - src). offset 0x40 + 0x4*n</description><addressOffset>0x040</addressOffset><resetValue>0x00000000</resetValue></register>
      </registers>
    </peripheral>

  </peripherals>
</device>
