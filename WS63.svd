        <register><name>DMAC_CHN_CONFIG_0</name><description>Channel 0 configuration register</description><addressOffset>0x0108</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>dmac_chn_en_0</name><description>Channel enable: 0=disable; 1=enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>dmac_s_peripheral_0</name><description>Source peripheral select</description><bitRange>[4:1]</bitRange><access>read-write</access></field><field><name>dmac_d_peripheral_0</name><description>Destination peripheral select</description><bitRange>[8:5]</bitRange><access>read-write</access></field><field><name>dmac_flow_ctl_0</name><description>Flow control: 000=mem2mem; 001=mem2per; 010=per2mem; 011=per2per(DMAC); 100=per2per(dst); 101=mem2per(dst); 110=per2mem(src); 111=per2per(src)</description><bitRange>[11:9]</bitRange><access>read-write</access></field><field><name>dmac_int_en_0</name><description>Error interrupt mask: 0=masked; 1=unmasked</description><bitRange>[12:12]</bitRange><access>read-write</access></field><field><name>dmac_int_tc_0</name><description>Transfer complete interrupt mask: 0=masked; 1=unmasked</description><bitRange>[13:13]</bitRange><access>read-write</access></field><field><name>dmac_lock_0</name><description>Bus lock: 0=disabled; 1=enabled</description><bitRange>[14:14]</bitRange><access>read-write</access></field><field><name>dmac_active_0</name><description>FIFO has data: 0=no; 1=yes</description><bitRange>[15:15]</bitRange><access>read-only</access></field><field><name>dmac_halt_0</name><description>Halt: 0=allow DMA; 1=ignore DMA requests</description><bitRange>[16:16]</bitRange><access>read-write</access></field></fields></register>

