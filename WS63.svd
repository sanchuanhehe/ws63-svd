      <interrupt><name>UART2_INT</name><value>55</value></interrupt>
    </peripheral>

    <!-- ============================================================ -->
    <!-- I2C0 (Base: 0x44018000)                                      -->
    <!-- ============================================================ -->
    <peripheral>
      <name>I2C0</name>
      <description>I2C0 master controller</description>
      <baseAddress>0x44018000</baseAddress>
      <interrupt><name>I2C0_INT</name><value>31</value></interrupt>
      <registers>
        <register><name>I2C_CTRL</name><description>I2C control register</description><addressOffset>0x00</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>int_done_mask</name><description>Transfer complete interrupt mask: 0=masked; 1=unmasked</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>int_arb_loss_mask</name><description>Arbitration loss interrupt mask</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>int_ack_err_mask</name><description>ACK error interrupt mask</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>int_rx_mask</name><description>RX interrupt mask</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>int_tx_mask</name><description>TX interrupt mask</description><bitRange>[4:4]</bitRange><access>read-write</access></field><field><name>int_stop_mask</name><description>Stop condition interrupt mask</description><bitRange>[5:5]</bitRange><access>read-write</access></field><field><name>int_start_mask</name><description>Start condition interrupt mask</description><bitRange>[6:6]</bitRange><access>read-write</access></field><field><name>int_mask</name><description>I2C interrupt master mask</description><bitRange>[7:7]</bitRange><access>read-write</access></field><field><name>i2c_en</name><description>I2C enable: 0=disabled; 1=enabled</description><bitRange>[8:8]</bitRange><access>read-write</access></field><field><name>int_rxtide_mask</name><description>RX FIFO overflow interrupt mask</description><bitRange>[9:9]</bitRange><access>read-write</access></field><field><name>int_txtide_mask</name><description>TX FIFO overflow interrupt mask</description><bitRange>[10:10]</bitRange><access>read-write</access></field><field><name>mode_ctrl</name><description>I2C mode: 0=no FIFO; 1=FIFO mode</description><bitRange>[11:11]</bitRange><access>read-write</access></field><field><name>int_txfifo_over_mask</name><description>TX FIFO complete interrupt mask</description><bitRange>[12:12]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_COM</name><description>I2C command register</description><addressOffset>0x04</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>op_stop</name><description>Generate stop condition: 0=end; 1=active</description><bitRange>[0:0]</bitRange><access>read-write</access></field><field><name>op_we</name><description>Generate write operation</description><bitRange>[1:1]</bitRange><access>read-write</access></field><field><name>op_rd</name><description>Generate read operation</description><bitRange>[2:2]</bitRange><access>read-write</access></field><field><name>op_start</name><description>Generate start condition</description><bitRange>[3:3]</bitRange><access>read-write</access></field><field><name>op_ack</name><description>Master RX ACK: 0=send ACK; 1=no ACK</description><bitRange>[4:4]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_ICR</name><description>I2C interrupt clear register</description><addressOffset>0x08</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>clr_int_done</name><description>Clear transfer complete interrupt</description><bitRange>[0:0]</bitRange><access>write-only</access></field><field><name>clr_int_arb_loss</name><description>Clear arbitration loss interrupt</description><bitRange>[1:1]</bitRange><access>write-only</access></field><field><name>clr_int_ack_err</name><description>Clear ACK error interrupt</description><bitRange>[2:2]</bitRange><access>write-only</access></field><field><name>clr_int_rx</name><description>Clear RX interrupt</description><bitRange>[3:3]</bitRange><access>write-only</access></field><field><name>clr_int_tx</name><description>Clear TX interrupt</description><bitRange>[4:4]</bitRange><access>write-only</access></field><field><name>clr_int_stop</name><description>Clear stop interrupt</description><bitRange>[5:5]</bitRange><access>write-only</access></field><field><name>clr_int_start</name><description>Clear start interrupt</description><bitRange>[6:6]</bitRange><access>write-only</access></field><field><name>clr_int_rxtide</name><description>Clear RX FIFO overflow interrupt</description><bitRange>[7:7]</bitRange><access>write-only</access></field><field><name>clr_int_txtide</name><description>Clear TX FIFO overflow interrupt</description><bitRange>[8:8]</bitRange><access>write-only</access></field><field><name>clr_int_txfifo_over</name><description>Clear TX FIFO complete interrupt</description><bitRange>[9:9]</bitRange><access>write-only</access></field></fields></register>
        <register><name>I2C_SR</name><description>I2C status register</description><addressOffset>0x0C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>int_done</name><description>Transfer complete interrupt flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>int_arb_loss</name><description>Arbitration loss interrupt flag</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>int_ack_err</name><description>ACK error interrupt flag</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>int_rx</name><description>RX interrupt flag</description><bitRange>[3:3]</bitRange><access>read-only</access></field><field><name>int_tx</name><description>TX interrupt flag</description><bitRange>[4:4]</bitRange><access>read-only</access></field><field><name>int_stop</name><description>Stop interrupt flag</description><bitRange>[5:5]</bitRange><access>read-only</access></field><field><name>int_start</name><description>Start interrupt flag</description><bitRange>[6:6]</bitRange><access>read-only</access></field><field><name>bus_busy</name><description>Bus busy: 0=idle; 1=busy</description><bitRange>[7:7]</bitRange><access>read-only</access></field><field><name>int_rxtide</name><description>RX FIFO overflow flag</description><bitRange>[8:8]</bitRange><access>read-only</access></field><field><name>int_txtide</name><description>TX FIFO overflow flag</description><bitRange>[9:9]</bitRange><access>read-only</access></field><field><name>int_txfifo_over</name><description>TX FIFO complete flag</description><bitRange>[10:10]</bitRange><access>read-only</access></field></fields></register>
        <register><name>I2C_SCL_H</name><description>SCL high period register</description><addressOffset>0x10</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>scl_h</name><description>SCL high period (value*2 = actual period)</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_SCL_L</name><description>SCL low period register</description><addressOffset>0x14</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>scl_l</name><description>SCL low period (value*2 = actual period)</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_TXR</name><description>I2C TX data register</description><addressOffset>0x18</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>i2c_txr</name><description>TX data byte</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_RXR</name><description>I2C RX data register</description><addressOffset>0x1C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>i2c_rxr</name><description>RX data byte</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>I2C_FIFOSTATUS</name><description>FIFO status register</description><addressOffset>0x20</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>txff</name><description>TX FIFO full: 0=not full; 1=full</description><bitRange>[0:0]</bitRange><access>read-only</access></field><field><name>txfe</name><description>TX FIFO empty: 0=not empty; 1=empty</description><bitRange>[1:1]</bitRange><access>read-only</access></field><field><name>rxff</name><description>RX FIFO full</description><bitRange>[2:2]</bitRange><access>read-only</access></field><field><name>rxfe</name><description>RX FIFO empty</description><bitRange>[3:3]</bitRange><access>read-only</access></field></fields></register>
        <register><name>I2C_TXCOUNT</name><description>TX FIFO count register</description><addressOffset>0x24</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>txcount</name><description>TX FIFO character count (write any value to clear TX FIFO)</description><bitRange>[5:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_RXCOUNT</name><description>RX FIFO count register</description><addressOffset>0x28</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>rxcount</name><description>RX FIFO character count (write any value to clear RX FIFO)</description><bitRange>[5:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_RXTIDE</name><description>RX FIFO threshold register</description><addressOffset>0x2C</addressOffset><resetValue>0x00000001</resetValue><fields><field><name>rxtide</name><description>RX FIFO overflow interrupt trigger value</description><bitRange>[5:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_TXTIDE</name><description>TX FIFO threshold register</description><addressOffset>0x30</addressOffset><resetValue>0x00000001</resetValue><fields><field><name>txtide</name><description>TX FIFO overflow interrupt trigger value</description><bitRange>[5:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>I2C_FTRPER</name><description>Glitch filter configuration register</description><addressOffset>0x34</addressOffset><resetValue>0x0000000F</resetValue><fields><field><name>ftrper</name><description>Glitch filter period in ic_clk cycles</description><bitRange>[3:0]</bitRange><access>read-write</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- I2C1 derived from I2C0 -->
    <peripheral derivedFrom="I2C0">
      <name>I2C1</name>
      <description>I2C1 master controller</description>
      <baseAddress>0x44018100</baseAddress>
      <interrupt><name>I2C1_INT</name><value>32</value></interrupt>
    </peripheral>

    <!-- ============================================================ -->
    <!-- PWM (Base: 0x44024000)                                       -->
    <!-- ============================================================ -->
    <peripheral>
      <name>PWM</name>
      <description>PWM controller with 8 channels</description>
      <baseAddress>0x44024000</baseAddress>
      <interrupt><name>PWM_ABNOR_INT</name><value>56</value></interrupt>
      <registers>
        <!-- Group registers (i=0..3) -->
        <register><name>PWM_SEL0</name><description>PWM group 0 select</description><addressOffset>0x000</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_sel_0</name><description>Group 0 PWM select, each bit corresponds to one PWM channel</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_STARTCLRCNT_EN0</name><description>PWM group 0 start clear counter enable</description><addressOffset>0x004</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_startclrcnt_en_0</name><description>Start clear counter enable for group 0</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_START0</name><description>PWM group 0 start</description><addressOffset>0x008</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_start_0</name><description>Start group 0 (self-clearing)</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PWM_SEL1</name><description>PWM group 1 select</description><addressOffset>0x010</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_sel_1</name><description>Group 1 PWM select</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_STARTCLRCNT_EN1</name><description>PWM group 1 start clear counter enable</description><addressOffset>0x014</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_startclrcnt_en_1</name><description>Start clear counter enable for group 1</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_START1</name><description>PWM group 1 start</description><addressOffset>0x018</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_start_1</name><description>Start group 1 (self-clearing)</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PWM_SEL2</name><description>PWM group 2 select</description><addressOffset>0x020</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_sel_2</name><description>Group 2 PWM select</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_STARTCLRCNT_EN2</name><description>PWM group 2 start clear counter enable</description><addressOffset>0x024</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_startclrcnt_en_2</name><description>Start clear counter enable for group 2</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_START2</name><description>PWM group 2 start</description><addressOffset>0x028</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_start_2</name><description>Start group 2 (self-clearing)</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PWM_SEL3</name><description>PWM group 3 select</description><addressOffset>0x030</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_sel_3</name><description>Group 3 PWM select</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_STARTCLRCNT_EN3</name><description>PWM group 3 start clear counter enable</description><addressOffset>0x034</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_startclrcnt_en_3</name><description>Start clear counter enable for group 3</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_START3</name><description>PWM group 3 start</description><addressOffset>0x038</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_start_3</name><description>Start group 3 (self-clearing)</description><bitRange>[0:0]</bitRange><access>write-only</access></field></fields></register>

        <!-- Per-channel registers (j=0..7, stride 0x40) -->
        <register><name>PWM_EN0</name><description>PWM0 enable</description><addressOffset>0x0100</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_en_0</name><description>PWM0 enable: 0=off; 1=on</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_PORTITY0</name><description>PWM0 polarity</description><addressOffset>0x0104</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_poarity_0</name><description>PWM0 polarity: 0=normal; 1=inverted</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_OEN_CFG0</name><description>PWM0 high-impedance config</description><addressOffset>0x0108</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_oen_cfg_0</name><description>PWM0 high-Z enable: 0=follow polarity; 1=high-Z when inactive</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_OFFSET_L0</name><description>PWM0 phase offset low 16 bits</description><addressOffset>0x010C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_offset_l_0</name><description>PWM0 phase offset low 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_OFFSET_H0</name><description>PWM0 phase offset high 16 bits</description><addressOffset>0x0110</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_offset_h_0</name><description>PWM0 phase offset high 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_FREQ_L0</name><description>PWM0 frequency low 16 bits</description><addressOffset>0x0114</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_freq_l_0</name><description>PWM0 clock divider low 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_FREQ_H0</name><description>PWM0 frequency high 16 bits</description><addressOffset>0x0118</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_freq_h_0</name><description>PWM0 clock divider high 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_DUTY_L0</name><description>PWM0 duty cycle low 16 bits</description><addressOffset>0x011C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_duty_l_0</name><description>PWM0 duty cycle low 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_DUTY_H0</name><description>PWM0 duty cycle high 16 bits</description><addressOffset>0x0120</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_duty_h_0</name><description>PWM0 duty cycle high 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_PERIODLOAD_FLAG0</name><description>PWM0 period load flag</description><addressOffset>0x0124</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_periodload_flag_0</name><description>Period load complete flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PWM_PERIOD_VAL0</name><description>PWM0 pulse count value</description><addressOffset>0x0128</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_period_val_0</name><description>Pulse count for stepping mode</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_PERIODCNT0</name><description>PWM0 pulse count current value</description><addressOffset>0x012C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_periodcnt_0</name><description>Current pulse count</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>

        <!-- PWM1 (offset 0x140) -->
        <register><name>PWM_EN1</name><description>PWM1 enable</description><addressOffset>0x0140</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_en_1</name><description>PWM1 enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_PORTITY1</name><description>PWM1 polarity</description><addressOffset>0x0144</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_poarity_1</name><description>PWM1 polarity</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_OEN_CFG1</name><description>PWM1 high-impedance config</description><addressOffset>0x0148</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_oen_cfg_1</name><description>PWM1 high-Z enable</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_OFFSET_L1</name><description>PWM1 phase offset low</description><addressOffset>0x014C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_offset_l_1</name><description>PWM1 phase offset low 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_OFFSET_H1</name><description>PWM1 phase offset high</description><addressOffset>0x0150</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_offset_h_1</name><description>PWM1 phase offset high 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_FREQ_L1</name><description>PWM1 frequency low</description><addressOffset>0x0154</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_freq_l_1</name><description>PWM1 clock divider low 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_FREQ_H1</name><description>PWM1 frequency high</description><addressOffset>0x0158</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_freq_h_1</name><description>PWM1 clock divider high 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_DUTY_L1</name><description>PWM1 duty cycle low</description><addressOffset>0x015C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_duty_l_1</name><description>PWM1 duty low 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_DUTY_H1</name><description>PWM1 duty cycle high</description><addressOffset>0x0160</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_duty_h_1</name><description>PWM1 duty high 16 bits</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_PERIODLOAD_FLAG1</name><description>PWM1 period load flag</description><addressOffset>0x0164</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_periodload_flag_1</name><description>Period load flag</description><bitRange>[0:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PWM_PERIOD_VAL1</name><description>PWM1 pulse count</description><addressOffset>0x0168</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_period_val_1</name><description>Pulse count</description><bitRange>[15:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_PERIODCNT1</name><description>PWM1 pulse count current</description><addressOffset>0x016C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_periodcnt_1</name><description>Current pulse count</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>

        <!-- Global PWM registers -->
        <register><name>PWM_ABNOR_STATE0</name><description>PWM abnormal state register 0</description><addressOffset>0x500</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_abnor_state0</name><description>Multi-channel config abnormal state, each bit per PWM</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PWM_ABNOR_STATE1</name><description>PWM abnormal state register 1</description><addressOffset>0x504</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_abnor_state1</name><description>Counter config abnormal state, each bit per PWM</description><bitRange>[15:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>PWM_ABNOR_STATE_CLR0</name><description>PWM abnormal state clear 0</description><addressOffset>0x508</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_abnor_state_clr0</name><description>Clear abnormal state 0 (self-clearing)</description><bitRange>[15:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PWM_ABNOR_STATE_CLR1</name><description>PWM abnormal state clear 1</description><addressOffset>0x50C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_abnor_state_clr1</name><description>Clear abnormal state 1 (self-clearing)</description><bitRange>[15:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>PWM_INT_MASK</name><description>PWM interrupt mask</description><addressOffset>0x510</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_int_mask</name><description>Interrupt mask: bit[0]=abnormal; bit[1]=stepping cycle end</description><bitRange>[1:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_DMA_EN</name><description>PWM DMA enable</description><addressOffset>0x514</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_dma_en</name><description>DMA enable: 0=disabled; 1=enabled</description><bitRange>[0:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>PWM_CFG_INT_CLR0</name><description>PWM stepping cycle end interrupt clear</description><addressOffset>0x518</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>pwm_cfg_int_clr0</name><description>Stepping cycle end interrupt clear (self-clearing)</description><bitRange>[15:0]</bitRange><access>write-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- DMA (Base: 0x4A000000)                                       -->
    <!-- ============================================================ -->
    <peripheral>
      <name>DMA</name>
      <description>DMA controller with 4 channels</description>
      <baseAddress>0x4A000000</baseAddress>
      <interrupt><name>DMA_INT</name><value>59</value></interrupt>
      <registers>
        <register><name>DMAC_INT_ST</name><description>Interrupt status register</description><addressOffset>0x0004</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>int_st</name><description>Channel interrupt status (after mask)</description><bitRange>[7:0]</bitRange><access>read-only</access></field><field><name>int_trans_st</name><description>Channel transfer interrupt status (after mask)</description><bitRange>[15:8]</bitRange><access>read-only</access></field><field><name>int_err_st</name><description>Channel error interrupt status (after mask)</description><bitRange>[23:16]</bitRange><access>read-only</access></field></fields></register>
        <register><name>DMAC_INT_CLR</name><description>Interrupt clear register</description><addressOffset>0x0008</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>int_trans_clr</name><description>Clear channel transfer interrupt</description><bitRange>[7:0]</bitRange><access>read-write</access></field><field><name>int_err_clr</name><description>Clear channel error interrupt</description><bitRange>[15:8]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DMAC_ORI_INT_ST</name><description>Raw interrupt status register</description><addressOffset>0x000C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>ori_int_trans_st</name><description>Raw transfer interrupt status (before mask)</description><bitRange>[7:0]</bitRange><access>read-only</access></field><field><name>ori_int_err_st</name><description>Raw error interrupt status (before mask)</description><bitRange>[15:8]</bitRange><access>read-only</access></field></fields></register>
        <register><name>DMAC_EN_CHNS</name><description>Channel enable query register</description><addressOffset>0x0010</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>en_chns</name><description>Channel enable status: 0=disabled; 1=enabled</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>DMAC_BURST_REQ</name><description>Burst software request register</description><addressOffset>0x0014</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>last_burst_req</name><description>Last burst request per peripheral</description><bitRange>[15:0]</bitRange><access>read-write</access></field><field><name>burst_req</name><description>Burst request per peripheral</description><bitRange>[31:16]</bitRange><access>read-write</access></field></fields></register>
        <register><name>DMAC_SINGLE_REQ</name><description>Single software request register</description><addressOffset>0x0018</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>last_single_req</name><description>Last single request per peripheral</description><bitRange>[15:0]</bitRange><access>read-write</access></field><field><name>single_req</name><description>Single request per peripheral</description><bitRange>[31:16]</bitRange><access>read-write</access></field></fields></register>
