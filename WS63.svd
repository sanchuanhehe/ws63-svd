<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.3" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <name>WS63</name>
  <version>1.0</version>
  <description>HiSilicon WS63 Wi-Fi/BLE/SLE Combo SoC</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <access>read-write</access>
  <resetValue>0x0</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>

  <cpu>
    <name>custom_riscv</name>
    <description>Custom RISC-V 32-bit processor, ISA: RV32IMFC_Zicsr (rv32i2p1_m2p0_f2p2_c2p0_zicsr2p0)</description>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>true</mpuPresent>
    <fpuPresent>true</fpuPresent>
    <fpuDP>false</fpuDP>
    <nvicPrioBits>3</nvicPrioBits>
    <vendorSystickConfig>false</vendorSystickConfig>
    <deviceNumInterrupts>64</deviceNumInterrupts>
    <sauNumRegions>0</sauNumRegions>
  </cpu>

  <peripherals>

    <!-- ============================================================ -->
    <!-- SYS_CTL1: Interrupt Controller (Base: 0x44000000)           -->
    <!-- ============================================================ -->
    <peripheral>
      <name>SYS_CTL1</name>
      <description>System Control 1 - Interrupt Controller</description>
      <baseAddress>0x44000000</baseAddress>
      <size>32</size>
      <access>read-write</access>
      <registers>
        <register>
          <name>NMI_INT</name>
          <displayName>NMI_INT</displayName>
          <description>WDT interrupt query and NMI interrupt configuration register</description>
          <addressOffset>0x0040</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>tee_nmi_int</name>
              <description>Software NMI interrupt configuration. 0: pull low CPU NMI soft interrupt; 1: pull high CPU NMI soft interrupt</description>
              <bitRange>[0:0]</bitRange>
              <access>read-write</access>
            </field>
            <field>
              <name>wdt_int</name>
              <description>Watchdog interrupt query. 0: WDT interrupt invalid; 1: WDT interrupt valid</description>
              <bitRange>[1:1]</bitRange>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SOFT_INT_EN</name>
          <displayName>SOFT_INT_EN</displayName>
          <description>CPU soft interrupt enable register</description>
          <addressOffset>0x0150</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>soft_int0_en</name>
              <description>CPU soft interrupt 0 enable. 0: disabled; 1: enabled</description>
              <bitRange>[0:0]</bitRange>
              <access>read-write</access>
            </field>
            <field>
              <name>soft_int1_en</name>
              <description>CPU soft interrupt 1 enable. 0: disabled; 1: enabled</description>
              <bitRange>[1:1]</bitRange>
              <access>read-write</access>
            </field>
            <field>
              <name>soft_int2_en</name>
              <description>CPU soft interrupt 2 enable. 0: disabled; 1: enabled</description>
              <bitRange>[2:2]</bitRange>
              <access>read-write</access>
            </field>
            <field>
              <name>soft_int3_en</name>
              <description>CPU soft interrupt 3 enable. 0: disabled; 1: enabled</description>
              <bitRange>[3:3]</bitRange>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SOFT_INT_SET</name>
          <displayName>SOFT_INT_SET</displayName>
          <description>CPU soft interrupt set register (self-clearing)</description>
          <addressOffset>0x0154</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>soft_int0_set</name>
              <description>CPU soft interrupt 0 set. 0: no effect; 1: set effective</description>
              <bitRange>[0:0]</bitRange>
              <access>write-only</access>
            </field>
            <field>
              <name>soft_int1_set</name>
              <description>CPU soft interrupt 1 set. 0: no effect; 1: set effective</description>
              <bitRange>[1:1]</bitRange>
              <access>write-only</access>
            </field>
            <field>
              <name>soft_int2_set</name>
              <description>CPU soft interrupt 2 set. 0: no effect; 1: set effective</description>
              <bitRange>[2:2]</bitRange>
              <access>write-only</access>
            </field>
            <field>
              <name>soft_int3_set</name>
              <description>CPU soft interrupt 3 set. 0: no effect; 1: set effective</description>
              <bitRange>[3:3]</bitRange>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SOFT_INT_CLR</name>
          <displayName>SOFT_INT_CLR</displayName>
          <description>CPU soft interrupt clear register (self-clearing)</description>
          <addressOffset>0x0158</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>soft_int0_clr</name>
              <description>CPU soft interrupt 0 clear. 0: no effect; 1: clear effective</description>
              <bitRange>[0:0]</bitRange>
              <access>write-only</access>
            </field>
            <field>
              <name>soft_int1_clr</name>
              <description>CPU soft interrupt 1 clear. 0: no effect; 1: clear effective</description>
              <bitRange>[1:1]</bitRange>
              <access>write-only</access>
            </field>
            <field>
              <name>soft_int2_clr</name>
              <description>CPU soft interrupt 2 clear. 0: no effect; 1: clear effective</description>
              <bitRange>[2:2]</bitRange>
              <access>write-only</access>
            </field>
            <field>
              <name>soft_int3_clr</name>
              <description>CPU soft interrupt 3 clear. 0: no effect; 1: clear effective</description>
              <bitRange>[3:3]</bitRange>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SOFT_INT_STS</name>
          <displayName>SOFT_INT_STS</displayName>
          <description>CPU soft interrupt status register</description>
          <addressOffset>0x015C</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>soft_int0_sts</name>
              <description>CPU soft interrupt 0 status. 0: no interrupt; 1: interrupt active</description>
              <bitRange>[0:0]</bitRange>
              <access>read-only</access>
            </field>
            <field>
              <name>soft_int1_sts</name>
              <description>CPU soft interrupt 1 status. 0: no interrupt; 1: interrupt active</description>
              <bitRange>[1:1]</bitRange>
              <access>read-only</access>
            </field>
            <field>
              <name>soft_int2_sts</name>
              <description>CPU soft interrupt 2 status. 0: no interrupt; 1: interrupt active</description>
              <bitRange>[2:2]</bitRange>
              <access>read-only</access>
            </field>
            <field>
              <name>soft_int3_sts</name>
              <description>CPU soft interrupt 3 status. 0: no interrupt; 1: interrupt active</description>
              <bitRange>[3:3]</bitRange>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>

    <!-- ============================================================ -->
    <!-- IO_CONFIG: IO Multiplexing and Pad Control (Base: 0x4400D000)-->
    <!-- ============================================================ -->
    <peripheral>
      <name>IO_CONFIG</name>
      <description>IO multiplexing and pad control</description>
      <baseAddress>0x4400D000</baseAddress>
      <size>32</size>
      <access>read-write</access>
      <registers>
        <!-- Pin mux select registers -->
        <register>
          <name>GPIO_00_SEL</name>
          <description>GPIO_00 pin mux select</description>
          <addressOffset>0x0</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_00_sel</name><description>GPIO_00 pin mux: 0:GPIO_00; 1:PWM0; 2:DIAG[0]; 3:SPI1_CSN; 4:JTAG_TDI</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_01_SEL</name>
          <description>GPIO_01 pin mux select</description>
          <addressOffset>0x4</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_01_sel</name><description>GPIO_01 pin mux: 0:GPIO_01; 1:PWM1; 2:DIAG[1]; 3:SPI1_IO0; 4:JTAG_MODE; 5:BT_SAMPLE</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_02_SEL</name>
          <description>GPIO_02 pin mux select</description>
          <addressOffset>0x8</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_02_sel</name><description>GPIO_02 pin mux: 0:GPIO_02; 1:PWM2; 2:DIAG[2]; 3:SPI1_IO3; 4:WIFI_TSF_SYNC; 5:WL_GLP_SYNC_PULSE; 6:BSLE_GLP_SYNC_PULSE</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_03_SEL</name>
          <description>GPIO_03 pin mux select</description>
          <addressOffset>0xC</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_03_sel</name><description>GPIO_03 pin mux: 0:GPIO_03; 1:PWM3; 2:PMU_32K_TEST; 3:SPI1_IO1; 4:HW_ID[0]; 5:DIAG[3]</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_04_SEL</name>
          <description>GPIO_04 pin mux select</description>
          <addressOffset>0x10</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_04_sel</name><description>GPIO_04 pin mux: 0:SSI_CLK; 1:PWM4; 2:GPIO_04; 3:SPI1_IO1; 4:JTAG_ENABLE; 5:DFT_JTAG_TMS</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_05_SEL</name>
          <description>GPIO_05 pin mux select</description>
          <addressOffset>0x14</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_05_sel</name><description>GPIO_05 pin mux: 0:SSI_DATA; 1:PWM5; 2:UART2_CTS; 3:SPI1_IO2; 4:GPIO_05; 5:SPI0_IN; 6:DFT_JTAG_TCK</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_06_SEL</name>
          <description>GPIO_06 pin mux select</description>
          <addressOffset>0x18</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_06_sel</name><description>GPIO_06 pin mux: 0:GPIO_06; 1:PWM6; 2:UART2_RTS; 3:SPI1_SCK; 4:REFCLK_FREQ_STATUS; 5:DIAG[4]; 6:SPI0_OUT; 7:DFT_JTAG_TDI</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_07_SEL</name>
          <description>GPIO_07 pin mux select</description>
          <addressOffset>0x1C</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_07_sel</name><description>GPIO_07 pin mux: 0:GPIO_07; 1:PWM7; 2:UART2_RXD; 3:SPI0_SCK; 4:I2S_MCLK; 5:DIAG[5]</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_08_SEL</name>
          <description>GPIO_08 pin mux select</description>
          <addressOffset>0x20</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_08_sel</name><description>GPIO_08 pin mux: 0:GPIO_08; 1:PWM0; 2:UART2_TXD; 3:SPI0_CS1_N; 4:DIAG[6]</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_09_SEL</name>
          <description>GPIO_09 pin mux select</description>
          <addressOffset>0x24</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_09_sel</name><description>GPIO_09 pin mux: 0:GPIO_09; 1:PWM1; 2:RADAR_ANT0_SW; 3:SPI0_OUT; 4:I2S_DO; 5:HW_ID[1]; 6:DIAG[7]; 7:JTAG_TDO</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_10_SEL</name>
          <description>GPIO_10 pin mux select</description>
          <addressOffset>0x28</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_10_sel</name><description>GPIO_10 pin mux: 0:GPIO_10; 1:PWM2; 2:ANT0_SW; 3:SPI0_CS0_N; 4:I2S_SCLK; 5:DIAG[0]</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_11_SEL</name>
          <description>GPIO_11 pin mux select</description>
          <addressOffset>0x2C</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_11_sel</name><description>GPIO_11 pin mux: 0:GPIO_11; 1:PWM3; 2:RADAR_ANT1_SW; 3:SPI0_IN; 4:I2S_LRCLK; 5:DIAG[1]; 6:HW_ID[2]</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_12_SEL</name>
          <description>GPIO_12 pin mux select</description>
          <addressOffset>0x30</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_12_sel</name><description>GPIO_12 pin mux: 0:GPIO_12; 1:PWM4; 2:ANT1_SW; 4:I2S_DI; 6:HW_ID[3]</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_13_SEL</name>
          <description>GPIO_13 pin mux select</description>
          <addressOffset>0x34</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_13_sel</name><description>GPIO_13 pin mux: 0:GPIO_13; 1:UART1_CTS; 2:RADAR_ANT0_SW; 3:DFT_JTAG_TDO; 4:JTAG_TMS</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>GPIO_14_SEL</name>
          <description>GPIO_14 pin mux select</description>
          <addressOffset>0x38</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>gpio_14_sel</name><description>GPIO_14 pin mux: 0:GPIO_14; 1:UART1_RTS; 2:RADAR_ANT1_SW; 3:DFT_JTAG_TRSTN; 4:JTAG_TCK</description><bitRange>[2:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>UART1_TXD_SEL</name>
          <description>UART1_TXD pin mux select</description>
          <addressOffset>0x3C</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>uart1_txd_sel</name><description>UART1_TXD pin mux: 0:GPIO_15; 1:UART1_TXD; 2:I2C1_SDA</description><bitRange>[1:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>UART1_RXD_SEL</name>
          <description>UART1_RXD pin mux select</description>
          <addressOffset>0x40</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>uart1_rxd_sel</name><description>UART1_RXD pin mux: 0:GPIO_16; 1:UART1_RXD; 2:I2C1_SCL</description><bitRange>[1:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>UART0_TXD_SEL</name>
          <description>UART0_TXD pin mux select</description>
          <addressOffset>0x44</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>uart0_txd_sel</name><description>UART0_TXD pin mux: 0:GPIO_17; 1:UART0_TXD; 2:I2C0_SDA</description><bitRange>[1:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>UART0_RXD_SEL</name>
          <description>UART0_RXD pin mux select</description>
          <addressOffset>0x48</addressOffset>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>uart0_rxd_sel</name><description>UART0_RXD pin mux: 0:GPIO_18; 1:UART0_RXD; 2:I2C0_SCL</description><bitRange>[1:0]</bitRange><access>read-write</access></field>
          </fields>
        </register>

        <!-- Pad control registers (base offset 0x800) -->
        <register>
          <name>PAD_GPIO_00_CTRL</name>
          <description>GPIO_00 pad control register</description>
          <addressOffset>0x800</addressOffset>
          <resetValue>0x00000800</resetValue>
          <fields>
            <field><name>pad_gpio_00_ctrl_st</name><description>Schmitt trigger: 0:No Schmitt; 1:Schmitt Enable</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_00_ctrl_ds0</name><description>Drive strength bit 0</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_00_ctrl_ds1</name><description>Drive strength bit 1</description><bitRange>[5:5]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_00_ctrl_ds2</name><description>Drive strength bit 2. DS2~DS0: 111~000, drive strength decreases</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_00_ctrl_pe</name><description>Pull enable. PE/PS: 00:no pull; 01:strong pull-up; 10:pull-down; 11:pull-up</description><bitRange>[9:9]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_00_ctrl_ps</name><description>Pull select. PE/PS: 00:no pull; 01:strong pull-up; 10:pull-down; 11:pull-up</description><bitRange>[10:10]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_00_ctrl_ie</name><description>Input enable: 0:input disabled; 1:input enabled</description><bitRange>[11:11]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>PAD_GPIO_01_CTRL</name>
          <description>GPIO_01 pad control register</description>
          <addressOffset>0x804</addressOffset>
          <resetValue>0x00000A00</resetValue>
          <fields>
            <field><name>pad_gpio_01_ctrl_st</name><description>Schmitt trigger: 0:No Schmitt; 1:Schmitt Enable</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_01_ctrl_ds0</name><description>Drive strength bit 0</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_01_ctrl_ds1</name><description>Drive strength bit 1</description><bitRange>[5:5]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_01_ctrl_ds2</name><description>Drive strength bit 2</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_01_ctrl_pe</name><description>Pull enable</description><bitRange>[9:9]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_01_ctrl_ps</name><description>Pull select</description><bitRange>[10:10]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_01_ctrl_ie</name><description>Input enable</description><bitRange>[11:11]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>PAD_GPIO_02_CTRL</name>
          <description>GPIO_02 pad control register</description>
          <addressOffset>0x808</addressOffset>
          <resetValue>0x00000800</resetValue>
          <fields>
            <field><name>pad_gpio_02_ctrl_st</name><description>Schmitt trigger</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_02_ctrl_ds0</name><description>Drive strength bit 0</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_02_ctrl_ds1</name><description>Drive strength bit 1</description><bitRange>[5:5]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_02_ctrl_ds2</name><description>Drive strength bit 2</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_02_ctrl_pe</name><description>Pull enable</description><bitRange>[9:9]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_02_ctrl_ps</name><description>Pull select</description><bitRange>[10:10]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_02_ctrl_ie</name><description>Input enable</description><bitRange>[11:11]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>PAD_GPIO_03_CTRL</name>
          <description>GPIO_03 pad control register</description>
          <addressOffset>0x80C</addressOffset>
          <resetValue>0x00000A00</resetValue>
          <fields>
            <field><name>pad_gpio_03_ctrl_st</name><description>Schmitt trigger</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_03_ctrl_ds0</name><description>Drive strength bit 0</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_03_ctrl_ds1</name><description>Drive strength bit 1</description><bitRange>[5:5]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_03_ctrl_ds2</name><description>Drive strength bit 2</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_03_ctrl_pe</name><description>Pull enable</description><bitRange>[9:9]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_03_ctrl_ps</name><description>Pull select</description><bitRange>[10:10]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_03_ctrl_ie</name><description>Input enable</description><bitRange>[11:11]</bitRange><access>read-write</access></field>
          </fields>
        </register>
        <register>
          <name>PAD_GPIO_04_CTRL</name>
          <description>GPIO_04 pad control register</description>
          <addressOffset>0x810</addressOffset>
          <resetValue>0x00000A00</resetValue>
          <fields>
            <field><name>pad_gpio_04_ctrl_st</name><description>Schmitt trigger</description><bitRange>[3:3]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_04_ctrl_ds0</name><description>Drive strength bit 0</description><bitRange>[4:4]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_04_ctrl_ds1</name><description>Drive strength bit 1</description><bitRange>[5:5]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_04_ctrl_ds2</name><description>Drive strength bit 2</description><bitRange>[6:6]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_04_ctrl_pe</name><description>Pull enable</description><bitRange>[9:9]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_04_ctrl_ps</name><description>Pull select</description><bitRange>[10:10]</bitRange><access>read-write</access></field>
            <field><name>pad_gpio_04_ctrl_ie</name><description>Input enable</description><bitRange>[11:11]</bitRange><access>read-write</access></field>
