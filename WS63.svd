    <!-- ============================================================ -->
    <!-- GPIO0 (Base: 0x44028000)                                     -->
    <!-- ============================================================ -->
    <peripheral>
      <name>GPIO0</name>
      <description>GPIO controller for GPIO[7:0]</description>
      <baseAddress>0x44028000</baseAddress>
      <interrupt><name>GPIO_INT0</name><value>33</value></interrupt>
      <registers>
        <register><name>GPIO_SW_OUT</name><description>GPIO data register</description><addressOffset>0x0000</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_sw_out</name><description>GPIO data. Output: written value drives I/O; Input: reads external port</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_SW_OEN</name><description>GPIO data direction register</description><addressOffset>0x0004</addressOffset><resetValue>0x000000FF</resetValue><fields><field><name>gpio_sw_oen</name><description>GPIO direction: 0=output; 1=input (default)</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_EN</name><description>GPIO interrupt enable register</description><addressOffset>0x000C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_en</name><description>Interrupt enable: 0=normal GPIO; 1=interrupt port</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_MASK</name><description>GPIO interrupt mask register</description><addressOffset>0x0010</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_mask</name><description>Interrupt mask: 0=not masked; 1=masked</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_TYPE</name><description>GPIO interrupt type register</description><addressOffset>0x0014</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_type</name><description>Interrupt type: 0=level; 1=edge</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_POLARITY</name><description>GPIO interrupt polarity register</description><addressOffset>0x0018</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_polarity</name><description>Interrupt polarity: 0=low/falling; 1=high/rising</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_DEDGE</name><description>GPIO dual-edge interrupt enable register</description><addressOffset>0x001C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_dedge</name><description>Dual-edge interrupt enable: 0=disabled; 1=enabled</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_DEBOUNCE</name><description>GPIO interrupt debounce control register</description><addressOffset>0x0020</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_debounce</name><description>Debounce enable: 0=disabled; 1=enabled</description><bitRange>[7:0]</bitRange><access>read-write</access></field></fields></register>
        <register><name>GPIO_INT_RAW</name><description>GPIO raw interrupt status register</description><addressOffset>0x0024</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_raw</name><description>Raw interrupt status (before mask): 0=no interrupt; 1=interrupt</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>GPIO_INTR</name><description>GPIO interrupt status register</description><addressOffset>0x0028</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_intr</name><description>Interrupt status (after mask): 0=no interrupt; 1=interrupt</description><bitRange>[7:0]</bitRange><access>read-only</access></field></fields></register>
        <register><name>GPIO_INT_EOI</name><description>GPIO interrupt clear register</description><addressOffset>0x002C</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_int_eoi</name><description>Edge interrupt clear: 0=no clear; 1=clear interrupt</description><bitRange>[7:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>GPIO_DATA_SET</name><description>GPIO data set register</description><addressOffset>0x0030</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_data_set</name><description>Write 1 to set corresponding GPIO_SW_OUT bits</description><bitRange>[7:0]</bitRange><access>write-only</access></field></fields></register>
        <register><name>GPIO_DATA_CLR</name><description>GPIO data clear register</description><addressOffset>0x0034</addressOffset><resetValue>0x00000000</resetValue><fields><field><name>gpio_data_clr</name><description>Write 1 to clear corresponding GPIO_SW_OUT bits</description><bitRange>[7:0]</bitRange><access>write-only</access></field></fields></register>
      </registers>
    </peripheral>

    <!-- GPIO1 derived from GPIO0 -->
    <peripheral derivedFrom="GPIO0">
      <name>GPIO1</name>
      <description>GPIO controller for GPIO[15:8]</description>
      <baseAddress>0x44029000</baseAddress>
      <interrupt><name>GPIO_INT1</name><value>34</value></interrupt>
    </peripheral>

    <!-- GPIO2 derived from GPIO0 -->
    <peripheral derivedFrom="GPIO0">
      <name>GPIO2</name>
